{
  "name": "ilaunchify",
  "version": "2.0.0",
  "private": true,
  "description": "iLaunchify v2 — two-sided marketplace for creators, manufacturers, and print providers in US-compliant supplements + food & beverage.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @ilaunchify/db generate",
    "db:migrate": "pnpm --filter @ilaunchify/db migrate",
    "db:studio": "pnpm --filter @ilaunchify/db studio",
    "compliance:dev": "cd services/compliance && uvicorn app.main:app --reload",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "dotenv-cli": "^7.4.4",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{md,json}": [
      "prettier --write"
    ]
  }
}
