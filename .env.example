# iLaunchify v2 — Environment template
# Copy to .env.local for local dev. NEVER commit .env or .env.local.

# ─── App ───────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (CockroachDB) ────────────────────────────────────────────
# Local Docker compose default:
DATABASE_URL=postgresql://root@localhost:26257/ilaunchify?sslmode=disable
# Cockroach Cloud Serverless example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.cockroachlabs.cloud:26257/ilaunchify?sslmode=verify-full

# ─── Auth.js v5 ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (optional, recommended)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email magic-link provider (Resend)
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=

# ─── Compliance service (Python/FastAPI) ───────────────────────────────
COMPLIANCE_SERVICE_URL=http://localhost:8000

# ─── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Connect (manufacturer + print provider payouts)
STRIPE_CONNECT_CLIENT_ID=

# ─── Object storage (Cloudflare R2) ─────────────────────────────────────
# Account ID is shown in the Cloudflare dashboard URL after /accounts/.
# API tokens are created under R2 > Manage R2 API Tokens (give read+write+list
# scope on a single bucket). Bucket name is exactly the bucket you created.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ilaunchify-uploads
# Optional — only if you set up a Cloudflare R2 custom domain for public reads.
# Without it, files are served via short-lived signed URLs (the V1 default).
R2_PUBLIC_URL=

# ─── Scheduled jobs (cron) ─────────────────────────────────────────────
# Shared secret protecting /api/cron/* routes. Vercel Cron passes this
# automatically via Authorization header. For external schedulers, send
# 'Authorization: Bearer $CRON_SECRET'.
CRON_SECRET=

# ─── Observability ─────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ilaunchify

# ─── Redis (queue + cache) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
