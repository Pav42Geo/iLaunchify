// =============================================================================
// iLaunchify v2 Prisma Schema — V1 Initial Release
// =============================================================================
//
// Ported and reorganized from FOD-reference/prisma/schema.prisma, with V1
// additions per the architecture decision docs in docs/.
//
// Reading order: enums → identity → marketplace identity → brand & products →
// ingredients & recipes → compliance → templates & design → assets → orders →
// payments → carts → consumers → market & rule packs.
//
// V1 STATUS: this is the initial schema. It compiles cleanly and supports
// every feature in the 12-week roadmap. Models marked "(V1.5+)" are
// declared so foreign keys exist but their UIs are not built in V1.
//
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS — IDENTITY & ROLES
// =============================================================================

enum UserRole {
  ADMIN
  CREATOR
  PARTNER
}

enum StripeAccountStatus {
  NONE
  PENDING
  RESTRICTED
  ACTIVE
  REJECTED
  DEAUTHORIZED
}

// =============================================================================
// ENUMS — PARTNER & SERVICE
// =============================================================================

enum PartnerStatus {
  DRAFT
  INVITED
  IN_PROGRESS
  UNDER_REVIEW
  ACTIVE
  SUSPENDED
}

enum ServiceType {
  MANUFACTURING
  COPACKING
  LABEL_PRINTING
}

enum ServiceStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum DisclosureLevel {
  FULL          // "Manufactured by Acme Foods, San Jose, CA"
  CITY_STATE    // "Manufactured for [Creator] in San Jose, CA"
  ANONYMOUS     // "Manufactured for [Creator] in the USA"
}

// =============================================================================
// ENUMS — BRAND, PRODUCT, RECIPE
// =============================================================================

enum BrandArchetype {
  HERO
  SAGE
  CAREGIVER
  EXPLORER
  CREATOR
  JESTER
  EVERYMAN
  INNOCENT
  LOVER
  MAGICIAN
  OUTLAW
  RULER
}

enum ProductCategory {
  FOOD
  BEVERAGE_FUNCTIONAL
  SUPPLEMENT
  // V1.5+: BEAUTY, PET_FOOD, BABY_FOOD
}

enum ProductStatus {
  DRAFT
  IN_REVIEW
  COMPLIANT
  PUBLISHED
  PAUSED
  ARCHIVED
}

enum RecipeStatus {
  DRAFT
  CALCULATED
  COMPLIANCE_CHECKED
  APPROVED
}

// =============================================================================
// ENUMS — COMPLIANCE
// =============================================================================

enum ComplianceCheckOutcome {
  PASSED
  PASSED_WITH_WARNINGS
  FAILED
}

enum ViolationSeverity {
  BLOCKING
  WARNING
}

enum RulePackStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
}

// =============================================================================
// ENUMS — TEMPLATE & DESIGN
// =============================================================================

enum TemplateStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
}

enum DesignStatus {
  DRAFT
  COMPLIANT
  PUBLISHED
  ARCHIVED
}

enum DieCutCategory {
  BOTTLE_WRAP
  TUB_LID
  POUCH_FRONT
  BOX_PANEL
  STICKER
  CUSTOM
}

enum DesignLibrarySource {
  CURATED
  AI_AUTHORED        // V1.5+
  PARTNER_SUBMITTED  // V2+
}

// =============================================================================
// ENUMS — ASSET
// =============================================================================

enum AssetType {
  LOGO
  PRODUCT_IMAGE
  HERO_IMAGE
  CLIPART
  ICON
  FONT
  TEMPLATE_THUMBNAIL
  LABEL_PDF
  COMPLIANCE_DOC
  OTHER
}

enum AssetSource {
  USER_UPLOAD
  TEMPLATE_RENDER
  AI_GENERATED       // V1.5+
}

// =============================================================================
// ENUMS — ORDER
// =============================================================================

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  ROUTING
  IN_FULFILLMENT
  READY_TO_SHIP
  SHIPPED
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
  ON_HOLD
  DISPUTED
}

enum DispatchType {
  PRODUCT
  LABEL
}

enum DispatchStatus {
  PENDING_ACCEPT
  ACCEPTED
  PRODUCING
  READY
  SHIPPED
  IN_TRANSIT
  DELIVERED
  DECLINED
  TIMED_OUT
  CANCELLED
}

enum DispatchDeclineReason {
  AT_CAPACITY
  CANNOT_FULFILL_SPEC
  PRICING_DISPUTE
  OTHER
}

// =============================================================================
// ENUMS — PAYMENTS
// =============================================================================

enum ChargeStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum TransferDestination {
  CREATOR
  MANUFACTURER
  PRINT_PROVIDER
}

enum TransferReason {
  PRODUCT_COST
  LABEL_COST
  CREATOR_PAYOUT
  CREATOR_BONUS
  REFUND_CLAWBACK
}

enum TransferStatus {
  PENDING
  READY
  EXECUTING
  COMPLETED
  FAILED
  REVERSED
}

enum RefundReason {
  DEFECTIVE
  WRONG_ITEM
  NOT_AS_DESCRIBED
  DAMAGED_IN_TRANSIT
  CHANGED_MIND
  COMPLIANCE_FAILURE
  OTHER
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum DisputeStatus {
  NEEDS_RESPONSE
  UNDER_REVIEW
  CHARGE_REFUNDED
  WON
  LOST
}

enum ClawbackStatus {
  PENDING_APPROVAL
  APPROVED
  EXECUTED
  WAIVED
}

// =============================================================================
// ENUMS — CART & STOREFRONT
// =============================================================================

enum CartStatus {
  ACTIVE
  CHECKING_OUT
  CONVERTED
  ABANDONED
}

// =============================================================================
// ENUMS — SOCIAL (V1.5+ UI; V1 table only)
// =============================================================================

enum SocialPlatform {
  INSTAGRAM
  TIKTOK
  YOUTUBE
  PINTEREST
  X
  FACEBOOK
}

// =============================================================================
// MARKETS & PLATFORM CONFIG
// =============================================================================

model Market {
  id              String   @id @default(cuid())
  code            String   @unique          // 'US' (V1 only); 'EU', 'CA', 'AU', 'UK' (V2+)
  name            String                    // 'United States — FDA'
  jurisdictionAct String                    // 'FDA', 'EFSA', etc.
  currency        String   @default("USD")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rulePacks       RulePack[]
  products        Product[]
}

// PlatformFeeConfig — historical revisions; never edit, only insert new rows
model PlatformFeeConfig {
  id              String   @id @default(cuid())
  baseRateBp      Int      // 1500 = 15%
  floorCents      Int      @default(100)
  effectiveFrom   DateTime
  notes           String?
  createdAt       DateTime @default(now())
}

// =============================================================================
// USER & AUTH (Auth.js v5 compatible)
// =============================================================================

model User {
  id                  String           @id @default(cuid())
  email               String           @unique
  emailVerified       DateTime?
  name                String?
  image               String?
  role                UserRole
  // Stripe Connect
  stripeAccountId     String?          @unique
  stripeAccountStatus StripeAccountStatus @default(NONE)
  // Auth.js v5 standard
  accounts            Account[]
  sessions            Session[]
  // Role-specific profile
  creatorProfile      CreatorProfile?
  partner             Partner?
  // Activity
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  // Outbound relations
  initiatedRefunds    Refund[]
  transferDestinations Transfer[]      @relation("TransferDestinationUser")
  complianceChecks    ComplianceCheck[]
}

// Auth.js v5 — Account (OAuth providers)
model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

// Auth.js v5 — Session (database session strategy)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Auth.js v5 — VerificationToken (email magic links)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// =============================================================================
// CREATOR PROFILE
// =============================================================================

model CreatorProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  handle              String   @unique             // public URL slug (also Brand.handle fallback)
  displayName         String
  bio                 String?
  audienceSizeBand    String?                      // "10K-100K", "100K-1M", "1M+"
  // Fee overrides
  feeRateOverrideBp   Int?
  feeRateOverrideReason String?
  // Returns window
  returnsWindowDays   Int      @default(14)
  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brands              Brand[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// =============================================================================
// PARTNER & PARTNER SERVICE
// =============================================================================

model Partner {
  id                String           @id @default(cuid())
  userId            String           @unique
  companyName       String
  legalName         String
  status            PartnerStatus    @default(DRAFT)
  // Lead capture metadata
  leadSource        String?
  leadNotes         String?
  // Documents at the company level
  websiteUrl        String?
  contactPhone      String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  postalCode        String?
  country           String           @default("US")
  // Relations
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  services          PartnerService[]
  clawbacks         PartnerClawback[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model PartnerService {
  id                 String                @id @default(cuid())
  partnerId          String
  type               ServiceType
  status             ServiceStatus         @default(DRAFT)
  // Capability shape varies by type; validated via Zod per-type
  capabilities       Json
  // Disclosure preference per service (per docs/USER_ROLES.md decision 2026-05-18)
  disclosureLevel    DisclosureLevel       @default(ANONYMOUS)
  // Print-provider specifics: which die-cuts this service supports
  dieCutSupport      PartnerServiceDieCut[]
  // Order routing — dispatches assigned to this service
  dispatches         OrderDispatch[]
  partner            Partner               @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@unique([partnerId, type])              // one service per type per partner
}

model PartnerClawback {
  id            String         @id @default(cuid())
  partnerId     String
  refundId      String?
  disputeId     String?
  amountCents   Int
  reason        String
  status        ClawbackStatus @default(PENDING_APPROVAL)
  createdAt     DateTime       @default(now())
  resolvedAt    DateTime?
  partner       Partner        @relation(fields: [partnerId], references: [id])
  refund        Refund?        @relation(fields: [refundId], references: [id])
  dispute       Dispute?       @relation(fields: [disputeId], references: [id])
}

// =============================================================================
// BRAND
// =============================================================================

model Brand {
  id                String         @id @default(cuid())
  creatorProfileId  String
  name              String
  handle            String         @unique           // public URL slug (storefront route)
  positioning       String?                          // short positioning statement
  // Visual identity
  colorPrimary      String?
  colorSecondary    String?
  colorAccent       String?
  fontDisplay       String?                          // from curated list
  fontBody          String?                          // from curated list
  logoAssetId       String?
  heroAssetId       String?
  // Voice & tone — structured fields the AI layer reads
  voiceArchetype    BrandArchetype?
  voiceFormality    Int?                             // 1..5
  voicePlayfulness  Int?                             // 1..5
  voiceWarmth       Int?                             // 1..5
  voiceNotes        String?                          // free-text overrides
  // Audience model — AI strategy generation input
  audienceAgeMin    Int?
  audienceAgeMax    Int?
  audienceInterests Json?                            // string[]
  audienceValues    Json?                            // string[]
  // Storefront content
  tagline           String?
  aboutText         String?
  isActive          Boolean        @default(true)
  // Relations
  creatorProfile    CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  socialAccounts    SocialAccount[]
  products          Product[]
  templates         Template[]
  designs           Design[]
  carts             Cart[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

// =============================================================================
// SOCIAL ACCOUNTS (V1.5+ UI; V1 table only)
// =============================================================================

model SocialAccount {
  id              String         @id @default(cuid())
  brandId         String
  platform        SocialPlatform
  externalUserId  String
  handle          String
  // Token references — actual tokens in a separate KMS/secret store
  accessTokenRef  String
  refreshTokenRef String?
  scope           String
  connectedAt     DateTime       @default(now())
  brand           Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  @@unique([brandId, platform])
}

// =============================================================================
// INGREDIENTS & RECIPES
// =============================================================================

model Ingredient {
  id              String   @id @default(cuid())
  // USDA reference (when available)
  usdaFdcId       String?  @unique
  name            String
  // Per-100g nutrition snapshot — fast read for calc engine
  nutritionPer100g Json    // { calories, totalFat, saturatedFat, ... }
  // Categorization
  category        String?
  isOrganic       Boolean  @default(false)
  // Allergen flags
  allergens       String[]                       // ["milk","wheat","sesame",...]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  // Relations
  recipeIngredients RecipeIngredient[]

  @@index([name])
  @@index([usdaFdcId])
}

model Recipe {
  id              String              @id @default(cuid())
  productId       String              @unique
  status          RecipeStatus        @default(DRAFT)
  servingsPerContainer Decimal
  servingSizeG    Decimal                              // grams per serving
  servingSizeDesc String?                              // "1 scoop (30g)"
  // Calculated nutrition (after calc engine runs) — cached
  nutritionProfile Json?
  // Relations
  product         Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredients     RecipeIngredient[]
  complianceChecks ComplianceCheck[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model RecipeIngredient {
  id              String   @id @default(cuid())
  recipeId        String
  ingredientId    String
  weightG         Decimal                                // grams per total recipe
  position        Int                                    // for descending-order display
  recipe          Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])
  @@unique([recipeId, ingredientId])
}

// =============================================================================
// PRODUCTS
// =============================================================================

model Product {
  id              String          @id @default(cuid())
  brandId         String
  marketId        String                                  // V1: always US
  slug            String                                  // storefront URL: /shop/{handle}/{slug}
  name            String
  description     String?
  category        ProductCategory
  status          ProductStatus   @default(DRAFT)
  priceCents      Int             @default(0)
  // Featured + ordering
  featured        Boolean         @default(false)
  displayOrder    Int             @default(0)
  // Inventory (V1: manufacturer-defined limit, no real-time per-order reserve)
  inventoryAvailable Int?
  // Disclosure level override (defaults to PartnerService's, but creator can override)
  disclosureLevelOverride DisclosureLevel?
  // Visual
  primaryImageAssetId String?
  // Relations
  brand           Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  market          Market            @relation(fields: [marketId], references: [id])
  recipe          Recipe?
  template        Template?         @relation(fields: [templateId], references: [id])
  templateId      String?
  designs         Design[]
  cartItems       CartItem[]
  orderItems      OrderItem[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([brandId, slug])
  @@index([brandId, status])
}

// =============================================================================
// RULE PACKS & COMPLIANCE
// =============================================================================

model RulePack {
  id              String           @id @default(cuid())
  externalId      String           @unique     // matches the JSON file id, e.g. "us-fda-food-2026.01"
  marketId        String
  productCategory ProductCategory                // FOOD | SUPPLEMENT
  name            String
  description     String?
  isActive        Boolean          @default(true)
  market          Market           @relation(fields: [marketId], references: [id])
  versions        RulePackVersion[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  @@unique([marketId, productCategory])
}

model RulePackVersion {
  id              String           @id @default(cuid())
  rulePackId      String
  version         String                          // semver; matches JSON
  effectiveFrom   DateTime
  fileRef         String                          // path to JSON file in services/compliance/app/rule_packs/
  status          RulePackStatus   @default(PUBLISHED)
  changesSummary  String?
  rulePack        RulePack         @relation(fields: [rulePackId], references: [id], onDelete: Cascade)
  complianceChecks ComplianceCheck[]
  createdAt       DateTime         @default(now())
  @@unique([rulePackId, version])
}

model ComplianceCheck {
  id                String                  @id @default(cuid())
  recipeId          String
  rulePackVersionId String
  // Inputs hash — same hash means same inputs, deterministic outputs
  inputsHash        String
  // Result
  outcome           ComplianceCheckOutcome
  violations        Json                    // Violation[]
  warnings          Json                    // Warning[]
  disclosures       Json                    // required disclosures (Contains:, DSHEA, iron warning, etc.)
  panelData         Json                    // rounded values + format metadata
  // Audit
  triggeredByUserId String?
  // Relations
  recipe            Recipe                  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rulePackVersion   RulePackVersion         @relation(fields: [rulePackVersionId], references: [id])
  triggeredByUser   User?                   @relation(fields: [triggeredByUserId], references: [id])
  createdAt         DateTime                @default(now())

  @@index([recipeId])
  @@index([rulePackVersionId])
  @@index([inputsHash])
}

// =============================================================================
// TEMPLATES & DESIGNS
// =============================================================================

model Template {
  id              String            @id @default(cuid())
  brandId         String                                  // brand-owned (vs. DesignLibraryItem which is platform-owned)
  name            String
  status          TemplateStatus    @default(DRAFT)
  dieCutTemplateId String                                 // every template targets a specific physical shape
  // Design library origin (if cloned from one)
  origLibraryItemId String?
  // Relations
  brand           Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  dieCutTemplate  DieCutTemplate    @relation(fields: [dieCutTemplateId], references: [id])
  origLibraryItem DesignLibraryItem? @relation(fields: [origLibraryItemId], references: [id])
  versions        TemplateVersion[]
  products        Product[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model TemplateVersion {
  id              String            @id @default(cuid())
  templateId      String
  version         Int                                     // monotonic increment
  designJson      Json                                    // Fabric.js serialized state
  // Generation lineage (for AI in V1.5+)
  source          AssetSource       @default(USER_UPLOAD)
  generationMeta  Json?
  // Compliance state at this version
  lastComplianceCheckId String?
  template        Template          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  designs         Design[]
  createdAt       DateTime          @default(now())
  @@unique([templateId, version])
}

// Design — a creator's in-progress or finalized design for a specific Product.
// Distinct from Template (which is the reusable starting point).
model Design {
  id              String           @id @default(cuid())
  productId       String
  brandId         String
  templateVersionId String?                              // which template version this started from
  status          DesignStatus     @default(DRAFT)
  // Relations
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  brand           Brand            @relation(fields: [brandId], references: [id])
  templateVersion TemplateVersion? @relation(fields: [templateVersionId], references: [id])
  versions        DesignVersion[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model DesignVersion {
  id              String       @id @default(cuid())
  designId        String
  version         Int
  designJson      Json                              // Fabric.js serialized state
  // Generation lineage
  source          AssetSource  @default(USER_UPLOAD)
  generationMeta  Json?
  // Export references
  exportedPdfAssetId String?
  exportedAt      DateTime?
  // Relations
  design          Design       @relation(fields: [designId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  @@unique([designId, version])
}

// =============================================================================
// DIE-CUT TEMPLATES (physical printing specs)
// =============================================================================

model DieCutTemplate {
  id              String                  @id @default(cuid())
  name            String
  slug            String                  @unique
  category        DieCutCategory
  widthMm         Float
  heightMm        Float
  outlineSvg      String                                  // SVG path of the cut outline
  bleedMm         Float                   @default(3.0)
  safeAreaMm      Float                   @default(3.0)
  isStandard      Boolean                 @default(true)
  isActive        Boolean                 @default(true)
  // 3D preview hint (V1.5+ uses this; V1 stores the value but doesn't render)
  model3dKey      String?
  // Relations
  templates       Template[]
  partnerServices PartnerServiceDieCut[]
  libraryItems    DesignLibraryItem[]
  createdAt       DateTime                @default(now())
}

// Junction: which die-cuts a LABEL_PRINTING service supports + per-partner overrides
model PartnerServiceDieCut {
  partnerServiceId  String
  dieCutTemplateId  String
  // Per-relationship overrides
  surchargeCents    Int?
  leadTimeDays      Int?
  notes             String?
  partnerService    PartnerService    @relation(fields: [partnerServiceId], references: [id], onDelete: Cascade)
  dieCutTemplate    DieCutTemplate    @relation(fields: [dieCutTemplateId], references: [id])
  @@id([partnerServiceId, dieCutTemplateId])
}

// =============================================================================
// DESIGN LIBRARY (curated platform-owned designs)
// =============================================================================

model DesignLibraryItem {
  id              String              @id @default(cuid())
  name            String
  description     String?
  category        DieCutCategory
  dieCutTemplateId String
  previewAssetId  String
  templateSpec    Json                                     // serialized design (layers, slots)
  tags            String[]                                 // ["minimal", "organic", ...]
  source          DesignLibrarySource @default(CURATED)
  generationMeta  Json?                                    // for AI_AUTHORED
  isActive        Boolean             @default(true)
  // Relations
  dieCutTemplate  DieCutTemplate      @relation(fields: [dieCutTemplateId], references: [id])
  clonedTemplates Template[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

// =============================================================================
// ASSETS
// =============================================================================

model Asset {
  id              String         @id @default(cuid())
  ownerType       String                                  // 'BRAND' | 'TEMPLATE' | 'DESIGN' | 'PARTNER' | 'PRODUCT' | 'LIBRARY' | 'PLATFORM'
  ownerId         String?                                  // FK to the relevant model
  type            AssetType
  source          AssetSource    @default(USER_UPLOAD)
  generationMeta  Json?                                    // null for non-AI; populated for AI_GENERATED
  // Storage
  storageKey      String         @unique                   // R2 key
  publicUrl       String?                                  // CDN URL (for public assets)
  mimeType        String
  sizeBytes       Int
  widthPx         Int?
  heightPx        Int?
  // Tracking
  isPublic        Boolean        @default(false)
  uploadedByUserId String?
  createdAt       DateTime       @default(now())

  @@index([ownerType, ownerId])
  @@index([type])
}

// =============================================================================
// ORDERS
// =============================================================================

model Order {
  id                  String         @id @default(cuid())
  brandId             String                                // single-brand-per-cart
  consumerUserId      String?                                // null for guest orders
  consumerEmail       String                                 // captured at checkout
  status              OrderStatus    @default(PENDING_PAYMENT)
  // Money (in cents)
  subtotalCents       Int                                    // pre-tax, pre-shipping (basis for fee)
  shippingCents       Int            @default(0)
  taxCents            Int            @default(0)
  totalCents          Int                                    // subtotal + tax + shipping
  // Routing references
  manufacturerServiceId String?
  printProviderServiceId String?
  // Timestamps
  paidAt              DateTime?
  deliveredAt         DateTime?
  // Notes
  internalNotes       String?
  // Relations
  consumerUser        ConsumerUser?  @relation(fields: [consumerUserId], references: [id])
  items               OrderItem[]
  dispatches          OrderDispatch[]
  charge              Charge?
  refunds             Refund[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([brandId, status])
  @@index([consumerEmail])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  unitPriceCents  Int                              // snapshot at order time
  totalCents      Int
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])
}

// OrderDispatch — one of N dispatches per Order. Per the dual-dispatch model:
// every Order has at least one PRODUCT dispatch (manufacturer) and one LABEL
// dispatch (print provider). They advance independently.
model OrderDispatch {
  id                String           @id @default(cuid())
  orderId           String
  type              DispatchType
  partnerServiceId  String
  status            DispatchStatus   @default(PENDING_ACCEPT)
  // Decline / timeout per docs/USER_ROLES.md decision 2026-05-18
  acceptDeadlineAt  DateTime                          // ASSIGNED + 24h default
  declinedAt        DateTime?
  declineReason     DispatchDeclineReason?
  declineNotes      String?
  rerouteCount      Int              @default(0)
  // Fulfillment
  shippedAt         DateTime?
  trackingCarrier   String?
  trackingNumber    String?
  deliveredAt       DateTime?
  // Costs (for transfer reference)
  costCents         Int
  // Relations
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  partnerService    PartnerService   @relation(fields: [partnerServiceId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([orderId])
  @@index([partnerServiceId, status])
}

// =============================================================================
// PAYMENTS (Stripe Connect)
// =============================================================================

model Charge {
  id                  String        @id @default(cuid())
  orderId             String        @unique
  stripeChargeId      String        @unique
  stripePaymentIntentId String
  amountCents         Int
  currency            String        @default("usd")
  applicationFeeCents Int                                  // platform's cut (withheld at charge time)
  status              ChargeStatus
  statementDescriptor String?
  // Relations
  order               Order         @relation(fields: [orderId], references: [id])
  transfers           Transfer[]
  refunds             Refund[]
  dispute             Dispute?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Transfer {
  id                  String              @id @default(cuid())
  chargeId            String
  destinationStripeId String
  destinationUserId   String
  destinationType     TransferDestination
  amountCents         Int
  reason              TransferReason
  stripeTransferId    String?             @unique
  status              TransferStatus      @default(PENDING)
  scheduledFor        DateTime?
  executedAt          DateTime?
  failureReason       String?
  reversedByRefundId  String?
  // Relations
  charge              Charge              @relation(fields: [chargeId], references: [id])
  destinationUser     User                @relation("TransferDestinationUser", fields: [destinationUserId], references: [id])
  reversedByRefund    Refund?             @relation(fields: [reversedByRefundId], references: [id])
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([status, scheduledFor])
  @@index([chargeId])
}

model Refund {
  id                  String       @id @default(cuid())
  chargeId            String
  orderId             String
  stripeRefundId      String       @unique
  amountCents         Int
  reason              RefundReason
  status              RefundStatus @default(PENDING)
  initiatedByUserId   String
  // Relations
  charge              Charge       @relation(fields: [chargeId], references: [id])
  order               Order        @relation(fields: [orderId], references: [id])
  initiatedByUser     User         @relation(fields: [initiatedByUserId], references: [id])
  clawbacks           PartnerClawback[]
  reversedTransfers   Transfer[]
  createdAt           DateTime     @default(now())
}

model Dispute {
  id                  String          @id @default(cuid())
  chargeId            String          @unique
  stripeDisputeId     String          @unique
  amountCents         Int
  reason              String
  status              DisputeStatus   @default(NEEDS_RESPONSE)
  evidenceDueBy       DateTime
  evidenceSubmittedAt DateTime?
  resolvedAt          DateTime?
  outcome             String?
  // Relations
  charge              Charge          @relation(fields: [chargeId], references: [id])
  clawbacks           PartnerClawback[]
  createdAt           DateTime        @default(now())
}

// =============================================================================
// CART & CONSUMER
// =============================================================================

model Cart {
  id              String     @id @default(cuid())
  sessionToken    String?    @unique             // anonymous carts
  consumerUserId  String?                         // logged-in carts (V1.5+)
  brandId         String                          // single-brand-per-cart
  status          CartStatus @default(ACTIVE)
  expiresAt       DateTime
  items           CartItem[]
  consumerUser    ConsumerUser? @relation(fields: [consumerUserId], references: [id])
  brand           Brand      @relation(fields: [brandId], references: [id])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([sessionToken])
  @@index([status, expiresAt])
}

model CartItem {
  id              String   @id @default(cuid())
  cartId          String
  productId       String
  quantity        Int
  priceAtAddCents Int                              // snapshot — protects against mid-cart price changes
  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])
  @@unique([cartId, productId])
}

// ConsumerUser — separate from User (creator/partner/admin role).
// V1: row created from Stripe Checkout email; no password.
// V1.5+: magic-link login adds login flow.
model ConsumerUser {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  emailVerifiedAt DateTime?
  lastSeenAt      DateTime @default(now())
  // Relations
  carts           Cart[]
  orders          Order[]
  createdAt       DateTime @default(now())
}
