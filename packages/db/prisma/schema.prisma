  INSTAGRAM
  TIKTOK
  YOUTUBE
  PINTEREST
  X
  FACEBOOK
}

// =============================================================================
// MARKETS & PLATFORM CONFIG
// =============================================================================

model Market {
  id              String   @id @default(cuid())
  code            String   @unique          // 'US' (V1 only); 'EU', 'CA', 'AU', 'UK' (V2+)
  name            String                    // 'United States — FDA'
  jurisdictionAct String                    // 'FDA', 'EFSA', etc. (regulator)
  currency        String   @default("USD")
  // V1 additions per docs/MARKETS_AND_REGIONS.md
  region          String?                   // display grouping: 'North America', 'EU', 'UK'
  status          MarketStatus @default(ACTIVE)
  defaultLanguageId String?
  // Policy JSON — validated by the rule pack; shape per market regulator:
  typography      Json?                     // { minFontSizePt, requiredFonts[], boldRules }
  allergenPolicy  Json?                     // { allergenList[], declarationFormat, ... }
  barcodeRules    Json?                     // { allowedSymbologies[], placementRules }
  // Legacy isActive kept for backward compat; new code reads `status` instead.
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Existing relations
  rulePacks       RulePack[]
  products        Product[]
  // V1 new relations
  defaultLanguage Language? @relation("DefaultLanguage", fields: [defaultLanguageId], references: [id])
  languages       MarketLanguage[]
  regions         Region[]
  configs         MarketConfig[]
  partnersServing PartnerMarketCert[]
  brandsTargeting BrandTargetMarket[]
}

// PlatformFeeConfig — historical revisions; never edit, only insert new rows
model PlatformFeeConfig {
  id              String   @id @default(cuid())
  baseRateBp      Int      // 1500 = 15%
  floorCents      Int      @default(100)
  effectiveFrom   DateTime
  notes           String?
  createdAt       DateTime @default(now())
}

// =============================================================================
// USER & AUTH (Auth.js v5 compatible)
// =============================================================================

model User {
  id                  String           @id @default(cuid())
  email               String           @unique
  emailVerified       DateTime?
  name                String?
  image               String?
  role                UserRole
  // Stripe Connect (used for partner payouts — partners only)
  stripeAccountId     String?          @unique
  stripeAccountStatus StripeAccountStatus @default(NONE)
  // Phase G6 — Stripe Customer for billing recurring production-run
  // subscriptions (creators only). Resolved on-demand by
  // createProductionSubscription() and cached here for reuse on
  // subsequent subscribe-and-save flows.
  stripeCustomerId    String?          @unique
  // Auth.js v5 standard
  accounts            Account[]
  sessions            Session[]
  // Role-specific profile
  creatorProfile      CreatorProfile?
  partner             Partner?
  // Activity
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  // Notification preferences — single quiet-hours window per user (any event
  // not delivered by email during this window is held until the window closes).
  // Stored as minutes-since-UTC-midnight so we don't fight timezones. Both
  // null = no quiet hours (deliver any time).
  quietHoursStartUtc  Int?                              // 0..1439, e.g. 22*60 for 10pm UTC
  quietHoursEndUtc    Int?                              // 0..1439, e.g. 7*60 for 7am UTC
  // Outbound relations
  initiatedRefunds    Refund[]
  transferDestinations Transfer[]      @relation("TransferDestinationUser")
  complianceChecks    ComplianceCheck[]
  auditLogs           AuditLog[]                       @relation("AuditLogActor")
  verifiedSections    PartnerVerificationSection[]     @relation("VerificationSectionVerifier")
  uploadedFiles       PartnerFile[]                    @relation("PartnerFileUploader")
  notifications       Notification[]
  notificationPreferences NotificationPreference[]
  creatorOrders       Order[]                          @relation("CreatorOrders")
  channelConnections  ChannelConnection[]              @relation("CreatorChannelConnections")
  // Phase G1 — in-progress checkout wizard drafts
  creatorCheckoutDrafts CheckoutDraft[]                @relation("CreatorCheckoutDrafts")
  // Phase G4 — addresses creators reuse across orders. Keyed off User
  // (not CreatorProfile) so partner users can have shipping addresses
  // for sample requests later without a schema change.
  creatorSavedAddresses CreatorSavedAddress[]          @relation("CreatorSavedAddresses")
  // Phase G6 — Subscribe & save recurring production runs.
  productionSubscriptions ProductionSubscription[]    @relation("CreatorProductionSubscriptions")
}

// Auth.js v5 — Account (OAuth providers)
model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

// Auth.js v5 — Session (database session strategy)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Auth.js v5 — VerificationToken (email magic links)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// =============================================================================
// CREATOR PROFILE
// =============================================================================

model CreatorProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  handle              String   @unique             // public URL slug (also Brand.handle fallback)
  displayName         String
  bio                 String?
  audienceSizeBand    String?                      // "10K-100K", "100K-1M", "1M+"
  // V1: 5-step onboarding stepper progress per docs/CREATOR_ONBOARDING.md.
  // Shape: { welcomeSeen, currentStep, completedSteps[], declaredTargetMarketIds[],
  //         step1CompletedAt, step2CompletedAt, ... } — mirrors the Partner pattern.
  // Cleared (or kept frozen) once all 5 steps are complete.
  onboardingProgress  Json?
  // R14.b — subscription tier drives feature gates across Studio (Export
  // PDF), Checkout (Subscribe & save), and Order detail (Get product
  // support). Defaults to MAKER so existing creators stay on the free
  // tier; flips up via Stripe Subscription webhooks once V1.1 lands.
  subscriptionTier    SubscriptionTier @default(MAKER)
  // R15.a — change tracking for the admin Tier Management module.
  // Whose hand last touched the tier + when. Null on creation so we
  // know "always been MAKER" vs "promoted on YYYY-MM-DD by admin X".
  tierChangedAt       DateTime?
  tierChangedById     String?
  // Fee overrides
  feeRateOverrideBp   Int?
  feeRateOverrideReason String?
  // Returns window
  returnsWindowDays   Int      @default(14)
  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brands              Brand[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// R14.b — three creator subscription tiers. Ordered low → high so we can
// derive rank in TypeScript without a lookup map. New tiers must be
// appended at the bottom to preserve rank ordering.
enum SubscriptionTier {
  MAKER
  BUILDER
  AGENCY
}

// R15.a — three partner subscription tiers per PLATFORM_SPEC §Tier 1
// "Production partner tiers". Naming locked. Ordered low → high so the
// same rank-comparison pattern (hasTier()) works for partner gates.
// Applies to every PartnerService.type (MANUFACTURING / LABEL_PRINTING /
// COPACKING / WAREHOUSE / ACCESSORY) — the ladder is uniform; the
// per-type promotion criteria differ and are encoded outside the enum.
enum PartnerTier {
  VERIFIED
  TRUSTED
  PREMIER
}

// R15.a — admin-editable subscription plan rows. Source-of-truth for
// every numeric value the platform used to hardcode (price, fee %,
// feature limits). One row per (audience, tier) combo: 3 creator plans
// + 3 partner plans in V1. Code field is the stable string identifier
// callers reference (e.g. lookupPlanFeature('creator_maker', 'max_brands')).
//
// Per Pavel 2026-05-30: tier remains the canonical column on profile
// rows; this table describes what each tier means. No FK from profile
// → plan — the (audience, tier) key is enough.
model SubscriptionPlan {
  id                String        @id @default(cuid())
  code              String        @unique           // "creator_maker", "partner_verified", etc.
  audience          PlanAudience
  // Display tier name (matches the enum value but lowercased for UI).
  tierName          String
  // Rank within audience for sort order. 0 = lowest, 2 = highest.
  tierOrder         Int
  // Public-facing pricing. 0 for free tiers (Maker, Verified).
  monthlyPriceCents Int           @default(0)
  annualPriceCents  Int           @default(0)
  active            Boolean       @default(true)
  description       String?
  // Relations
  features          PlanFeature[]
  feeRules          FeeRule[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([audience, tierOrder])
}

// R15.a — flexible per-plan feature row. intValue / boolValue /
// stringValue is a tagged-union pattern — exactly one is populated
// based on the feature's nature. Callers know the right type at the
// code-constant level. Null intValue + boolValue + stringValue means
// "unlimited" / "no cap" for limit-style features.
model PlanFeature {
  id          String           @id @default(cuid())
  planId      String
  // Stable identifier referenced at the call site (e.g. 'max_brands',
  // 'subscribe_and_save', 'support_sla_hours'). Owned by the module
  // that ships the gate.
  code        String
  intValue    Int?
  stringValue String?
  boolValue   Boolean?
  // Human-readable label / description shown in the admin editor.
  label       String
  description String?
  plan        SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, code])
  @@index([code])
}

// R15.a — pluggable fee-rate row. Keyed by (planId, triggerEvent) so a
// future "warehouse_referral" or "sample_order" event can hang its own
// rate off a plan without a schema change. Null planId = global default
// fallback. Either ratePercent or flatCents is set; both null = no fee
// (used to express "Premier gets zero platform fee on sample orders").
model FeeRule {
  id           String            @id @default(cuid())
  planId       String?
  triggerEvent String                                 // "production_order_subtotal", "sample_order", "warehouse_referral"
  ratePercent  Decimal?          @db.Decimal(5, 2)   // 15.00 = 15%
  flatCents    Int?
  minCents     Int?                                   // Floor (e.g. $1 minimum platform fee per order)
  maxCents     Int?                                   // Cap (rare, but supports "$500 max fee per order")
  active       Boolean           @default(true)
  notes        String?
  plan         SubscriptionPlan? @relation(fields: [planId], references: [id])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([planId, triggerEvent])
  @@index([triggerEvent])
}

// R15.a — which side of the marketplace a SubscriptionPlan applies to.
// Drives the audience tab in the admin Plans editor and keeps creator
// vs partner feature codes from colliding.
enum PlanAudience {
  CREATOR
  PARTNER
}

// =============================================================================
// PARTNER & PARTNER SERVICE
// =============================================================================

model Partner {
  id                String           @id @default(cuid())
  userId            String           @unique
  companyName       String
  legalName         String
  status            PartnerStatus    @default(DRAFT)
  // Lead capture metadata
  leadSource        String?
  leadNotes         String?
  // Documents at the company level
  websiteUrl        String?
  contactPhone      String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  postalCode        String?
  country           String           @default("US")
  // Onboarding wizard progress — tracks which steps a partner has completed,
  // so the wizard can resume after partial completion and "Edit section" deep-links
  // from My Application can jump to the right step. Shape:
  //   { currentStep: "documents", completedSteps: ["company", "service"], updatedAt: "..." }
  // Cleared on first ACTIVE transition.
  onboardingProgress    Json?
  // V1: geographic + market scoping per docs/MARKETS_AND_REGIONS.md
  primaryRegionId       String?                                    // FK to Region (state-level); nullable until partner provides
  // V1: FSM transition tracking per docs/PARTNER_ONBOARDING.md §3
  statusChangedAt       DateTime?
  statusChangedById     String?                                    // User who triggered the last status change (null for SYSTEM)
  statusChangeReason    String?
  // R15.a — Production-partner subscription tier (Verified → Trusted →
  // Premier per PLATFORM_SPEC §Tier 1). Default VERIFIED but only
  // meaningful once `status` flips to ACTIVE — every gate at the call
  // site should also check status. Promotion is admin-manual in V1
  // (audit-logged via AuditLog); cron-driven auto-promotion lands V1.1.
  tier                  PartnerTier      @default(VERIFIED)
  tierChangedAt         DateTime?
  tierChangedById       String?                                    // Admin who last changed the tier (null for SYSTEM auto-promote in V1.1+)
  // R15.a — Per-partner commission-rate override (basis points). Mirrors
  // CreatorProfile.feeRateOverrideBp. When non-null, the platform fee
  // pipeline uses this instead of the plan-level FeeRule for this
  // partner's orders. Reason is required at the admin UI so the audit
  // trail records why a partner got special treatment.
  feeRateOverrideBp     Int?
  feeRateOverrideReason String?
  // Relations
  user                  User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  services              PartnerService[]
  clawbacks             PartnerClawback[]
  verificationSections  PartnerVerificationSection[]
  files                 PartnerFile[]
  // V1 new relations (markets/regions)
  primaryRegion         Region?                       @relation("PartnerPrimaryRegion", fields: [primaryRegionId], references: [id])
  marketsCert           PartnerMarketCert[]
  // V1 new relations (5-layer onboarding — 1:1 each, populated as the partner advances)
  operationalCapability PartnerOperationalCapability?
  operationalStandards  PartnerOperationalStandards?
  commercialTerms       PartnerCommercialTerms?
  integrationCapability PartnerIntegrationCapability?
  onboardingState       PartnerOnboardingProgress?
  // V1 new relations (ingredient sourcing)
  privateIngredients    Ingredient[]                    @relation("PartnerPrivateIngredients")
  // V1 new relations (manufacturer product builder — packaging + certificates)
  packagingSystems      PackagingSystem[]
  certificateInstances  PartnerCertificateInstance[]
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
}

model PartnerService {
  id                 String                @id @default(cuid())
  partnerId          String
  type               ServiceType
  status             ServiceStatus         @default(DRAFT)
  // Capability shape varies by type; validated via Zod per-type
  capabilities       Json
  // Disclosure preference per service (per docs/USER_ROLES.md decision 2026-05-18)
  disclosureLevel    DisclosureLevel       @default(ANONYMOUS)
  // Print-provider specifics: which die-cuts this service supports
  dieCutSupport      PartnerServiceDieCut[]
  // Order routing — dispatches assigned to this service
  dispatches         OrderDispatch[]
  // When this service is type=WAREHOUSE: production orders that ship to it
  warehouseOrders    Order[]               @relation("WarehouseShipToOrders")
  // Catalog — ProductTemplates this manufacturer service offers (V1.1+)
  productTemplates   ProductTemplate[]
  // V1.5+ Phase F — print finishes this service offers (printer/label-printing
  // services only; hidden on the creator side until ≥1 ACTIVE row exists).
  partnerFinishes    PartnerFinish[]
  // Phase G3 — typed substrate + packaging-material declarations. Drives
  // the creator-side ProductionStep pickers + marketplace partner
  // matching (#153). Empty arrays mean "uses platform defaults."
  partnerServiceSubstrates         PartnerServiceSubstrate[]
  partnerServicePackagingMaterials PartnerServicePackagingMaterial[]
  partner            Partner               @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@unique([partnerId, type])              // one service per type per partner
}

model PartnerClawback {
  id            String         @id @default(cuid())
  partnerId     String
  refundId      String?
  disputeId     String?
  amountCents   Int
  reason        String
  status        ClawbackStatus @default(PENDING_APPROVAL)
  createdAt     DateTime       @default(now())
  resolvedAt    DateTime?
  partner       Partner        @relation(fields: [partnerId], references: [id])
  refund        Refund?        @relation(fields: [refundId], references: [id])
  dispute       Dispute?       @relation(fields: [disputeId], references: [id])
}

// =============================================================================
// BRAND
// =============================================================================

model Brand {
  id                String         @id @default(cuid())
  creatorProfileId  String
  name              String
  handle            String         @unique           // public URL slug (storefront route)
  positioning       String?                          // short positioning statement
  // === Brand Assets (V1 corrected scope per docs/DESIGN_STUDIO_REBUILD.md §4) ===
  // The brand identity in iLaunchify is a packaging-design ASSET LIBRARY that
  // feeds the Fabric.js canvas — NOT a web design-system editor. Per memory note
  // ilaunchify-brand-assets-not-design-system.md (2026-05-25 scope correction).
  //
  // What the canvas consumes:
  //   - Colors  → color pickers (text / background / ink) get brand swatches pinned at the top
  //   - Fonts   → Text drawer font dropdown gets brand fonts pinned at the top
  //   - Logos   → Images drawer "My Brand" section gets logo variants for drag-onto-canvas
  //
  // Colors: 3 named slots (primary/secondary/accent) for the canonical brand triad,
  // plus an optional brandSwatches[] for additional swatches (cap ~5 total in UI).
  colorPrimary      String?                                       // #16a34a etc; surfaces in canvas color pickers
  colorSecondary    String?
  colorAccent       String?
  brandSwatches     String[]                                      // optional 4th/5th swatches beyond the primary 3
  // Fonts: list of 1-3 TypographyFont IDs (typically heading + body + optional accent).
  // No PairId / ScaleRatio — those were web-design-system concepts (typographic scales,
  // pair lockups) that don't apply to packaging design where the canvas tools choose
  // per-element size.
  brandFontIds      String[]                                      // FK-ish to TypographyFont.id (validated in app code)
  // Logos: PRIMARY is the master mark. ICON + HORIZONTAL are the most commonly-used
  // variants. VERTICAL / MONOGRAM / INVERSE / FAVICON dropped — creators get confused
  // by the distinctions (per Pavel feedback 2026-05-26) and label designers rarely
  // need more than 3 logo variants in V1.
  logoAssetId       String?                                       // PRIMARY logo mark
  logoIconAssetId   String?                                       // icon-only variant
  logoHorizontalAssetId String?                                   // horizontal lockup
  heroAssetId       String?                                       // brand hero image (used in marketing surfaces if any)
  // Tagline — single string. secondaryTaglines[] dropped (over-build).
  tagline           String?
  aboutText         String?
  isActive          Boolean        @default(true)
  // V1 — geographic + market scoping per docs/MARKETS_AND_REGIONS.md
  operatingRegionId String?                                       // brand's home region (US state V1)
  // Onboarding completion flag (creator launch checklist Step 4)
  onboardingCompletedAt   DateTime?                               // null until creator has filled in brand basics
  // Relations
  creatorProfile          CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  socialAccounts          SocialAccount[]
  products                Product[]
  templates               Template[]
  designs                 Design[]
  orders                  Order[]
  // Phase G6 — Subscribe & save recurring production runs.
  productionSubscriptions ProductionSubscription[]
  operatingRegion         Region?        @relation("BrandOperatingRegion", fields: [operatingRegionId], references: [id])
  targetMarkets           BrandTargetMarket[]
  onboardingState         CreatorOnboardingProgress?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
}

// =============================================================================
// SOCIAL ACCOUNTS (V1.5+ UI; V1 table only)
// =============================================================================

model SocialAccount {
  id              String         @id @default(cuid())
  brandId         String
  platform        SocialPlatform
  externalUserId  String
  handle          String
  // Token references — actual tokens in a separate KMS/secret store
  accessTokenRef  String
  refreshTokenRef String?
  scope           String
  connectedAt     DateTime       @default(now())
  brand           Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  @@unique([brandId, platform])
}

// =============================================================================
// INGREDIENTS & RECIPES
// =============================================================================

model Ingredient {
  id              String   @id @default(cuid())
  // Legacy fields (preserved for back-compat with rows created before 2026-05-24):
  usdaFdcId       String?  @unique                       // populated for USDA-sourced rows
  name            String                                  // legacy display name; new code reads internalName
  nutritionPer100g Json                                   // { calories, totalFat, saturatedFat, ... } — also the canonical V1 nutrient profile
  category        String?                                 // legacy free-text category
  isOrganic       Boolean  @default(false)
  allergens       String[]                                // legacy ["milk","wheat","sesame"]; new code reads allergenFlags
  // V1 — three-tier sourcing per docs/MANUFACTURER_PRODUCT_BUILDER.md §4a
  source             IngredientSource?                    // nullable until backfilled; new rows must set
  sourceRefId        String?                              // FDC fdc_id (mirrors usdaFdcId for USDA), library slug, or partner UUID
  internalName       String?                              // 'Symrise Natural Vanilla 67-B' — used in recipe editor / cost / COA matching
  labelDeclarationName String?                            // 'Natural Flavor' — printed on FDA label; defaults to internalName if unset
  densityGPerML      Float?                               // for volume↔mass conversion
  allergenFlags      String[]                             // canonical Big-9 set ["milk","eggs","fish","shellfish","tree_nuts","peanuts","wheat","soybeans","sesame"] + iLaunchify-extended
  complianceNotes    String?                              // e.g. 'FDA class I nutrient', '21 CFR exemption'
  // V1 — verification governance per docs/MANUFACTURER_PRODUCT_BUILDER.md §4a.5
  verificationStatus VerificationStatus @default(LIBRARY_PROMOTED)  // USDA/seed = LIBRARY_PROMOTED; partner-private = SELF_ATTESTED by default
  coaFileId          String?                              // optional uploaded COA PDF (PartnerFile)
  createdById        String?                              // User who created (null for USDA-imported)
  verifiedById       String?                              // admin User who verified (null until ADMIN_VERIFIED)
  ownerPartnerId     String?                              // NULL for USDA + LIBRARY; partner id for PARTNER_PRIVATE
  promotedFromIngredientId String?                        // breadcrumb if this LIBRARY row was promoted from a PRIVATE one
  // V1 — bioengineered disclosure per USDA BE Standard 2022 (Recipal parity, FOD admin delta §1.5e)
  bioengineeredStatus BioengineeredStatus @default(NOT_APPLICABLE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  // Relations
  recipeIngredients RecipeIngredient[]
  // Catalog roles — same ingredient can serve as a base, replacement, or optional across templates
  templateSlotsAsBase    TemplateIngredientSlot[]        @relation("SlotBaseIngredient")
  templateReplacements   TemplateIngredientReplacement[] @relation("ReplacementIngredient")
  templateOptionals      TemplateOptionalIngredient[]    @relation("OptionalIngredient")
  // V1 new relations
  ownerPartner            Partner?     @relation("PartnerPrivateIngredients", fields: [ownerPartnerId], references: [id])
  promotedFrom            Ingredient?  @relation("IngredientPromotionLineage", fields: [promotedFromIngredientId], references: [id])
  promotedTo              Ingredient[] @relation("IngredientPromotionLineage")
  usageStats              IngredientUsage[]

  @@index([name])
  @@index([usdaFdcId])
  @@index([source, sourceRefId])
  @@index([ownerPartnerId])
  @@index([verificationStatus])
}

model Recipe {
  id              String              @id @default(cuid())
  productId       String              @unique
  status          RecipeStatus        @default(DRAFT)
  servingsPerContainer Decimal
  servingSizeG    Decimal                              // grams per serving
  servingSizeDesc String?                              // "1 scoop (30g)"
  // Calculated nutrition (after calc engine runs) — cached
  nutritionProfile Json?
  // Relations
  product         Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredients     RecipeIngredient[]
  complianceChecks ComplianceCheck[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model RecipeIngredient {
  id              String   @id @default(cuid())
  recipeId        String
  ingredientId    String
  weightG         Decimal                                // grams per total recipe
  position        Int                                    // for descending-order display
  // Track where this ingredient came from when the recipe was resolved.
  // V1: every catalog-driven Product fills this in. Legacy rows = null.
  source          ProductIngredientSource?
  // For TEMPLATE_BASE / TEMPLATE_REPLACEMENT: links back to the slot it filled.
  // Lets us reconstruct the creator's customization choices.
  filledSlotId    String?
  recipe          Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])
  filledSlot      TemplateIngredientSlot? @relation(fields: [filledSlotId], references: [id])
  @@unique([recipeId, ingredientId])
}

enum ProductIngredientSource {
  TEMPLATE_BASE          // creator kept the manufacturer's default
  TEMPLATE_REPLACEMENT   // creator swapped to one of the offered alternatives
  TEMPLATE_OPTIONAL      // creator toggled an optional ingredient on
}

// =============================================================================
// PRODUCTS
// =============================================================================

model Product {
  id              String          @id @default(cuid())
  brandId         String
  marketId        String                                  // V1: always US
  slug            String                                  // storefront URL: /shop/{handle}/{slug}
  name            String
  description     String?
  category        ProductCategory
  status          ProductStatus   @default(DRAFT)
  priceCents      Int             @default(0)
  // Featured + ordering
  featured        Boolean         @default(false)
  displayOrder    Int             @default(0)
  // Inventory (V1: manufacturer-defined limit, no real-time per-order reserve)
  inventoryAvailable Int?
  // Disclosure level override (defaults to PartnerService's, but creator can override)
  disclosureLevelOverride DisclosureLevel?
  // Visual
  primaryImageAssetId String?
  // Catalog binding — every V1 creator product starts from a ProductTemplate
  // chosen from the admin-curated catalog (nullable to keep schema migration
  // additive; new flows require it).
  productTemplateId String?
  variantId         String?
  // Inventory-vs-storefront publishing — creators can do either or both
  publishedToStorefront Boolean @default(false)
  inventoryOrderQty Int?                                    // if creator pre-bought their own stock

  // ---- Retail identity (GTIN / UPC) ----
  // Optional GTIN — UPC-A (12), EAN-13 (13), EAN-8 (8), or ITF-14 (14).
  // Required only when the creator intends to sell on Amazon / Walmart /
  // Target etc. Empty for DTC-only launches. See [[ilaunchify-gtin-model]].
  gtin            String?         @unique
  gtinSource      GtinSource      @default(USER_PROVIDED)
  // Free-form internal SKU — printed as Code 128 when barcodeMode = INTERNAL_SKU,
  // so creators can ship pre-launch samples / beta batches before their GS1
  // registration completes. Distinct from gtin: SKUs are not retail-safe.
  internalSku     String?
  barcodeMode     BarcodeMode     @default(NONE)
  // Relations
  brand           Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  market          Market            @relation(fields: [marketId], references: [id])
  recipe          Recipe?
  template        Template?         @relation(fields: [templateId], references: [id])
  templateId      String?
  productTemplate ProductTemplate?  @relation(fields: [productTemplateId], references: [id])
  variant         ProductTemplateVariant? @relation(fields: [variantId], references: [id])
  designs         Design[]
  orderItems      OrderItem[]
  channelLinks    ChannelProductLink[]
  // Phase G1 — in-progress checkout drafts
  checkoutDrafts  CheckoutDraft[]
  // Phase G6 — Subscribe & save recurring production runs.
  productionSubscriptions ProductionSubscription[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([brandId, slug])
  @@index([brandId, status])
  @@index([productTemplateId])
}

// =============================================================================
// RULE PACKS & COMPLIANCE
// =============================================================================

model RulePack {
  id              String           @id @default(cuid())
  externalId      String           @unique     // matches the JSON file id, e.g. "us-fda-food-2026.01"
  marketId        String
  productCategory ProductCategory                // FOOD | SUPPLEMENT
  name            String
  description     String?
  isActive        Boolean          @default(true)
  market          Market           @relation(fields: [marketId], references: [id])
  versions        RulePackVersion[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  @@unique([marketId, productCategory])
}

model RulePackVersion {
  id              String           @id @default(cuid())
  rulePackId      String
  version         String                          // semver; matches JSON
  effectiveFrom   DateTime
  fileRef         String                          // path to JSON file in services/compliance/app/rule_packs/
  status          RulePackStatus   @default(PUBLISHED)
  changesSummary  String?
  rulePack        RulePack         @relation(fields: [rulePackId], references: [id], onDelete: Cascade)
  complianceChecks ComplianceCheck[]
  createdAt       DateTime         @default(now())
  @@unique([rulePackId, version])
}

model ComplianceCheck {
  id                String                  @id @default(cuid())
  recipeId          String
  rulePackVersionId String
  // Inputs hash — same hash means same inputs, deterministic outputs
  inputsHash        String
  // Result
  outcome           ComplianceCheckOutcome
  violations        Json                    // Violation[]
  warnings          Json                    // Warning[]
  disclosures       Json                    // required disclosures (Contains:, DSHEA, iron warning, etc.)
  panelData         Json                    // rounded values + format metadata
  // Audit
  triggeredByUserId String?
  // Relations
  recipe            Recipe                  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rulePackVersion   RulePackVersion         @relation(fields: [rulePackVersionId], references: [id])
  triggeredByUser   User?                   @relation(fields: [triggeredByUserId], references: [id])
  createdAt         DateTime                @default(now())

  @@index([recipeId])
  @@index([rulePackVersionId])
  @@index([inputsHash])
}

// =============================================================================
// TEMPLATES & DESIGNS
// =============================================================================

model Template {
  id              String            @id @default(cuid())
  brandId         String                                  // brand-owned (vs. DesignLibraryItem which is platform-owned)
  name            String
  status          TemplateStatus    @default(DRAFT)
  dieCutTemplateId String                                 // every template targets a specific physical shape
  // Design library origin (if cloned from one)
  origLibraryItemId String?
  // Relations
  brand           Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  dieCutTemplate  DieCutTemplate    @relation(fields: [dieCutTemplateId], references: [id])
  origLibraryItem DesignLibraryItem? @relation(fields: [origLibraryItemId], references: [id])
  versions        TemplateVersion[]
  products        Product[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model TemplateVersion {
  id              String            @id @default(cuid())
  templateId      String
  version         Int                                     // monotonic increment
  designJson      Json                                    // Fabric.js serialized state
  // Generation lineage (for AI in V1.5+)
  source          AssetSource       @default(USER_UPLOAD)
  generationMeta  Json?
  // Compliance state at this version
  lastComplianceCheckId String?
  template        Template          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  designs         Design[]
  createdAt       DateTime          @default(now())
  @@unique([templateId, version])
}

// Design — a creator's in-progress or finalized design for a specific Product.
// Distinct from Template (which is the reusable starting point).
model Design {
  id              String           @id @default(cuid())
  productId       String
  brandId         String
  templateVersionId String?                              // which template version this started from
  status          DesignStatus     @default(DRAFT)
  // Relations
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  brand           Brand            @relation(fields: [brandId], references: [id])
  templateVersion TemplateVersion? @relation(fields: [templateVersionId], references: [id])
  versions        DesignVersion[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model DesignVersion {
  id              String       @id @default(cuid())
  designId        String
  version         Int
  designJson      Json                              // Fabric.js serialized state
  // Generation lineage
  source          AssetSource  @default(USER_UPLOAD)
  generationMeta  Json?
  // Export references
  exportedPdfAssetId String?
  exportedAt      DateTime?
  // Relations
  design          Design       @relation(fields: [designId], references: [id], onDelete: Cascade)
  // V1.5+ Phase F — print finishes the creator applied to this design version.
  finishApplications DesignFinishApplication[]
  // Phase G8 — OrderItems that locked in this version. Lets us refuse
  // delete on a version with a paid order against it.
  orderItems      OrderItem[]
  createdAt       DateTime     @default(now())
  @@unique([designId, version])
}

// =============================================================================
// PRINT FINISHES — admin-curated FinishType catalog, partner-offered
// PartnerFinish rows, per-design DesignFinishApplication. Per
// docs/PRINT_FINISHES_PLAN.md Phase F1.
// =============================================================================

model FinishType {
  id            String              @id @default(cuid())
  slug          String              @unique
  name          String
  category      FinishCategory
  description   String
  // Default application modes this finish CAN support — partners can restrict
  // to a subset when they add their offering.
  applicationModes ApplicationMode[]
  // Reference / "what it looks like" sample (admin-uploaded)
  exampleAssetId String?
  // Printer-facing default spec text — used as a starting template when
  // partner doesn't override.
  defaultPrinterSpec String?
  status        BrandLibraryStatus  @default(ACTIVE) // DRAFT | ACTIVE | DEPRECATED
  // Relations
  partnerFinishes PartnerFinish[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model PartnerFinish {
  id                String        @id @default(cuid())
  partnerServiceId  String                          // Scoped to a specific service
  finishTypeId      String
  // Partner-friendly overrides
  name              String?                         // "Premium Spot UV" instead of "Spot UV Gloss"
  description       String?                         // Sales copy + technical notes for the creator
  // Pricing model — see PRINT_FINISHES_PLAN.md §3
  pricingMode       FinishPricingMode
  basePriceCents    Int           @default(0)       // Setup fee per order
  perUnitPriceCents Int           @default(0)       // Per printed unit
  pricePerSqInCents Int?                            // For PER_AREA mode
  pricePerObjectCents Int?                          // For PER_OBJECT mode
  pricePerColorCents Int?                           // For PER_COLOR mode
  pricingTiers      Json?                           // For TIERED — [{ minQty, perUnitCents }]
  // Lead-time + MOQ impact
  leadTimeDays      Int           @default(0)       // Added to base lead time
  moqMin            Int           @default(0)       // Min order qty for this finish
  // Application
  availableModes    ApplicationMode[]               // Subset of FinishType.applicationModes
  // Substrate compatibility — slugs of substrates this finish works on. Per
  // Pavel's correction substrate selection lives in the post-canvas checkout
  // stepper (Phase G); this list is read by the Finishes drawer to hide
  // incompatible finishes once the creator has picked a substrate.
  compatibleSubstrates String[]
  maxCoveragePct    Float?                          // % of total area; e.g. some finishes max at 30% area
  // Sample assets — what this looks like on a real product
  sampleAssetIds    String[]
  // Status
  status            FinishStatus  @default(DRAFT)
  // Relations
  partnerService    PartnerService @relation(fields: [partnerServiceId], references: [id], onDelete: Cascade)
  finishType        FinishType     @relation(fields: [finishTypeId], references: [id])
  applications      DesignFinishApplication[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([partnerServiceId, status])
  @@index([finishTypeId])
}

model DesignFinishApplication {
  id              String          @id @default(cuid())
  designVersionId String
  partnerFinishId String
  // Application detail
  applicationMode ApplicationMode
  // For OBJECT_SELECTION — fabric customId stamps the creator picked.
  objectRefs      String[]
  // For COLOR_BASED — hex colors the creator picked.
  colorFilters    String[]
  // For REGION_MASK — polygon points in mm, relative to trim box origin.
  regionPolygons  Json?           // [[{x,y}, ...], ...]
  // For UPLOADED_MASK — asset id of the mask layer (PDF / PNG with alpha).
  maskAssetId     String?
  // Creator note to the printer (free text)
  creatorNotes    String?
  // Cached cost at last save — re-computed on every change so the Studio
  // shows a live cost without re-pricing on every render.
  estimatedPerUnitCents Int       @default(0)
  estimatedSetupCents   Int       @default(0)
  coverageSqIn    Float?
  objectCount     Int?
  spotColorCount  Int?
  // Relations
  designVersion   DesignVersion   @relation(fields: [designVersionId], references: [id], onDelete: Cascade)
  partnerFinish   PartnerFinish   @relation(fields: [partnerFinishId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([designVersionId])
}

enum FinishCategory {
  SURFACE
  FOIL_METALLIC
  EMBOSS_TEXTURE
  CUT
  INK
  SPECIAL
  // SUBSTRATE intentionally absent — material selection lives in the
  // post-canvas checkout stepper (Phase G), not the Design Studio.
}

enum ApplicationMode {
  WHOLE_DESIGN          // Whole label/whole panel
  TEXT_ONLY             // All text objects
  IMAGE_ONLY            // All image objects
  TEXT_AND_IMAGES       // All non-NFR objects
  OBJECT_SELECTION      // Creator picks specific objects (most powerful)
  REGION_MASK           // Creator draws a polygon mask
  COLOR_BASED           // Apply wherever specific colors appear
  UPLOADED_MASK         // Creator uploads a separate mask layer PDF/PNG
}

enum FinishPricingMode {
  FLAT_PER_ORDER     // One-time setup fee, no per-unit
  PER_UNIT           // Same cost per printed unit
  PER_AREA           // Per square inch (or square mm) of coverage
  PER_OBJECT         // Per object selected
  PER_COLOR          // Per spot color used
  TIERED             // Volume tiers
}

enum FinishStatus {
  DRAFT
  ACTIVE
  DISCONTINUED
}

// =============================================================================
// DIE-CUT TEMPLATES (physical printing specs)
// =============================================================================

model DieCutTemplate {
  id              String                  @id @default(cuid())
  name            String
  slug            String                  @unique
  category        DieCutCategory
  widthMm         Float
  heightMm        Float
  outlineSvg      String                                  // SVG path of the cut outline
  bleedMm         Float                   @default(3.0)
  safeAreaMm      Float                   @default(3.0)
  isStandard      Boolean                 @default(true)
  isActive        Boolean                 @default(true)
  // 3D preview hint (V1.5+ uses this; V1 stores the value but doesn't render)
  model3dKey      String?
  // Relations
  templates       Template[]
  partnerServices PartnerServiceDieCut[]
  libraryItems    DesignLibraryItem[]
  templateVariants ProductTemplateVariant[]
  createdAt       DateTime                @default(now())
}

// Junction: which die-cuts a LABEL_PRINTING service supports + per-partner overrides
model PartnerServiceDieCut {
  partnerServiceId  String
  dieCutTemplateId  String
  // Per-relationship overrides
  surchargeCents    Int?
  leadTimeDays      Int?
  notes             String?
  partnerService    PartnerService    @relation(fields: [partnerServiceId], references: [id], onDelete: Cascade)
  dieCutTemplate    DieCutTemplate    @relation(fields: [dieCutTemplateId], references: [id])
  @@id([partnerServiceId, dieCutTemplateId])
}

// =============================================================================
// DESIGN LIBRARY (curated platform-owned designs)
// =============================================================================

model DesignLibraryItem {
  // Conceptual name in spec docs: "LabelDesignTemplate" (docs/DESIGN_STUDIO.md §3).
  // The Studio's template gallery filters this table by the compatibility fields
  // below + the creator's brand.brandVoiceTags overlap with styleTags.
  id              String              @id @default(cuid())
  name            String
  description     String?
  category        DieCutCategory
  dieCutTemplateId String
  previewAssetId  String
  templateSpec    Json                                     // serialized design (layers, slots)
  // Legacy fields (preserved for back-compat):
  tags            String[]                                 // ["minimal", "organic", ...] — superseded by styleTags
  source          DesignLibrarySource @default(CURATED)    // superseded by createdBy
  isActive        Boolean             @default(true)       // superseded by lifecycleStatus
  generationMeta  Json?                                    // for AI_AUTHORED
  // V1 compatibility fields driving Design Studio auto-filtering
  // (per docs/DESIGN_STUDIO.md §3 + task #148)
  compatiblePackagingTypeIds  String[]                     // FK-ish to PackagingType.id; empty = compatible with any
  compatibleSurfaces          LabelTemplateSurface[]       // FRONT | BACK | LID | FULL_WRAP | SLEEVE | NECK
  productCategoryFit          String[]                     // e.g., ['SUPPLEMENT', 'BEVERAGE', 'SAUCE']
  styleTags                   String[]                     // matches Brand.brandVoiceTags vocab (minimalist|vintage|bold|organic|scientific|luxury|playful|wellness|athletic|clinical)
  // V1 tier model — billing flow lands V1.5
  tier                        LabelTemplateTier  @default(REGULAR)
  priceCents                  Int?                         // PREMIUM only
  exclusiveSeats              Int?                         // EXCLUSIVE only (default 5 per spec; nullable for REGULAR/PREMIUM)
  exclusiveLicenseHolders     String[]                     // partnerIds (or brandIds) that have claimed seats
  // V1 provenance — supports V2 AI Template Agent pipeline
  createdBy                   LabelTemplateCreator  @default(ADMIN)
  aiSubAgent                  String?                      // when createdBy=AI_AGENT (e.g., 'Generator-v1', 'Generator-v2-personalized')
  trendReportId               String?                      // V2 — links to DesignTrendReport when AI-generated
  humanCuratorId              String?                      // admin User who approved ACTIVE
  // V1 lifecycle (distinct from legacy isActive boolean)
  lifecycleStatus             LabelTemplateStatus  @default(DRAFT)
  // Relations
  dieCutTemplate  DieCutTemplate      @relation(fields: [dieCutTemplateId], references: [id])
  clonedTemplates Template[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  @@index([lifecycleStatus, tier])
}

// =============================================================================
// ASSETS
// =============================================================================

model Asset {
  id              String         @id @default(cuid())
  ownerType       String                                  // 'BRAND' | 'TEMPLATE' | 'DESIGN' | 'PARTNER' | 'PRODUCT' | 'LIBRARY' | 'PLATFORM'
  ownerId         String?                                  // FK to the relevant model
  type            AssetType
  source          AssetSource    @default(USER_UPLOAD)
  generationMeta  Json?                                    // null for non-AI; populated for AI_GENERATED
  // Storage
  storageKey      String         @unique                   // R2 key
  publicUrl       String?                                  // CDN URL (for public assets)
  mimeType        String
  sizeBytes       Int
  widthPx         Int?
  heightPx        Int?
  // Tracking
  isPublic        Boolean        @default(false)
  uploadedByUserId String?
  createdAt       DateTime       @default(now())

  @@index([ownerType, ownerId])
  @@index([type])
}

// =============================================================================
// ORDERS
// =============================================================================

// Order = a creator's production order. Per the 2026-05-19 model correction,
// iLaunchify is B2B production: the creator pays iLaunchify for a batch, and
// the goods ship to either the creator's own address or a connected
// WAREHOUSE partner. End-consumer purchases happen on the creator's external
// channels (Shopify, Amazon, etc.) and never touch iLaunchify.
// =============================================================================
// PRODUCTION OPTIONS — typed catalog for the Phase G3 checkout wizard.
//
// Per the G3 standardisation commitment (memory:
// [[ilaunchify-g3-standardize-capabilities]]), substrate and packaging
// material are first-class admin-curated tables, NOT freeform JSON inside
// PartnerService.capabilities. This drives:
//
//   * the creator-side ProductionStep pickers in the checkout wizard,
//   * partner-matching for marketplace routing (#153),
//   * cost estimation in OrderSummary,
//   * the manifest emitted alongside the production-order export bundle.
//
// Per-partner pricing + lead-time overrides land on the junction tables.
// =============================================================================

model Substrate {
  id                String            @id @default(cuid())
  slug              String            @unique
  name              String
  category          SubstrateCategory
  description       String
  // Base per-unit cost surcharge (cents) when no partner override applies.
  // Compared against the cheapest option in the same category — keeps the
  // wizard's "this choice +$0.04" microcopy honest.
  baseUnitCostCents Int               @default(0)
  // Sustainability indicator — surfaces a leaf icon in the picker.
  sustainabilityTier SustainabilityTier @default(STANDARD)
  // Hints which finish categories work on this substrate. Compared
  // against PartnerFinish.compatibleSubstrates[] when the Finishes drawer
  // grays out incompatible picks. Empty = no known incompatibilities.
  finishCompatibility String[]
  // Admin lifecycle state — DRAFT hidden from pickers, ACTIVE shown,
  // DEPRECATED grayed out with replacement hint in V1.5+.
  status            BrandLibraryStatus @default(ACTIVE)
  // Relations
  partnerServiceSubstrates PartnerServiceSubstrate[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model PackagingMaterial {
  id                String                @id @default(cuid())
  slug              String                @unique
  name              String
  topology          PackagingTopology     // BOTTLE → glass/plastic, JAR → glass/PP, etc.
  description       String
  baseUnitCostCents Int                   @default(0)
  // FDA / FSANZ / EFSA food-contact-safe flag. Required true for any
  // product where category=FOOD or BEVERAGE_FUNCTIONAL.
  foodSafe          Boolean               @default(true)
  sustainabilityTier SustainabilityTier   @default(STANDARD)
  status            BrandLibraryStatus    @default(ACTIVE)
  // Relations
  partnerServicePackagingMaterials PartnerServicePackagingMaterial[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([topology, status])
}

enum SubstrateCategory {
  PAPER_COATED          // matte / gloss coated paper labels
  PAPER_UNCOATED        // natural / textured uncoated paper
  KRAFT_RECYCLED        // recycled brown kraft (eco-friendly)
  FILM_BOPP             // synthetic film (durable, water-resistant)
  FILM_CLEAR            // transparent film (no-label look)
  FILM_METALLIC         // foil-finish substrate
  SPECIALTY             // textured / fabric / wood-grain / etc.
}

enum SustainabilityTier {
  STANDARD              // baseline
  RECYCLED              // post-consumer recycled content
  COMPOSTABLE           // certified compostable
  BIODEGRADABLE         // biodegradable but not compostable
}

// Junction — which substrates a LABEL_PRINTING partner service supports,
// with optional per-partner price + lead-time overrides.
model PartnerServiceSubstrate {
  id                  String        @id @default(cuid())
  partnerServiceId    String
  substrateId         String
  // Override the substrate's baseUnitCostCents for this partner. NULL
  // means use the substrate default. Surfaces in the wizard as the
  // partner's actual quoted price.
  perUnitCostCents    Int?
  // Additional lead-time days when this substrate is chosen (some
  // substrates take longer to print on).
  extraLeadTimeDays   Int           @default(0)
  // MOQ specific to this substrate (e.g., foil-finish substrates need a
  // larger run to amortise setup). NULL = use service default.
  moqMin              Int?
  // Status — DRAFT means partner is testing internally, ACTIVE shows
  // it in the picker, DISCONTINUED hides without breaking historical
  // OrderItem references.
  status              FinishStatus  @default(ACTIVE)
  partnerService      PartnerService @relation(fields: [partnerServiceId], references: [id], onDelete: Cascade)
  substrate           Substrate     @relation(fields: [substrateId], references: [id])
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([partnerServiceId, substrateId])
  @@index([partnerServiceId, status])
}

// Junction — which packaging materials a MANUFACTURING partner service
// supports. Same shape as PartnerServiceSubstrate.
model PartnerServicePackagingMaterial {
  id                  String        @id @default(cuid())
  partnerServiceId    String
  packagingMaterialId String
  perUnitCostCents    Int?
  extraLeadTimeDays   Int           @default(0)
  moqMin              Int?
  status              FinishStatus  @default(ACTIVE)
  partnerService      PartnerService @relation(fields: [partnerServiceId], references: [id], onDelete: Cascade)
  packagingMaterial   PackagingMaterial @relation(fields: [packagingMaterialId], references: [id])
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([partnerServiceId, packagingMaterialId])
  @@index([partnerServiceId, status])
}

// Phase G4 — addresses creators save for reuse across production orders.
// Surfaced in the wizard's Fulfillment step as the SAVED_ADDRESS picker.
// Soft-delete pattern is overkill at V1 scale; a hard delete cascades from
// the User row.
model CreatorSavedAddress {
  id              String   @id @default(cuid())
  creatorUserId   String
  label           String                                 // "Home", "Studio", "Lower-East 3PL", etc.
  contactName     String
  contactPhone    String?
  addressLine1    String
  addressLine2    String?
  city            String
  state           String?
  postalCode      String
  country         String   @default("US")
  // The first address the creator saves becomes the default automatically.
  // Switching the default toggles the prior one's flag in the same txn.
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  creator         User     @relation("CreatorSavedAddresses", fields: [creatorUserId], references: [id], onDelete: Cascade)

  @@index([creatorUserId, isDefault])
}

// Phase G1 — pre-Order wizard state. The 7-step checkout wizard at
// /products/[id]/checkout persists into this table between steps so the
// creator can leave and resume. On final "Pay" the draft converts into a
// real Order row + Stripe Checkout session (G5).
//
// One in-progress draft per (creator, product) — picking up where you left
// off is the default UX; starting fresh just overwrites the row.
model CheckoutDraft {
  id              String   @id @default(cuid())
  creatorUserId   String
  productId       String
  // The wizard's working state — schema lives in apps/creator's wizard
  // types. Shape is roughly:
  //   { step, quantity, substrateSlug, packagingMaterialSlug,
  //     finishApplications[], shipTo: { type, savedAddressId?, address? },
  //     accessoryItemIds[], viralAssetRequests[], promoCode,
  //     designVersionId, updatedAt }
  state           Json
  // Which step the creator was on last (1-7). Drives the stepper's
  // resume-from highlight.
  currentStep     Int      @default(1)
  // Highest step completed so far. Lets the stepper render check-marks
  // for the steps behind the current cursor.
  completedSteps  Int[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  // Relations
  creator         User     @relation("CreatorCheckoutDrafts", fields: [creatorUserId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([creatorUserId, productId])
  @@index([creatorUserId, updatedAt(sort: Desc)])
}

// =============================================================================
// Phase G6 — Production Subscriptions
// =============================================================================
//
// When a creator accepts the Subscribe & save offer at checkout Step 3, we
// create a ProductionSubscription that owns the recurring cadence: every
// MONTHLY or QUARTERLY cycle, Stripe fires `invoice.payment_succeeded` and
// our webhook spawns a new Order using the locked manifestSnapshot below.
//
// The first Order on signup still flows through the normal one-time
// placeOrderFromCheckoutDraft path — the subscription only governs the
// SECOND order onwards. That keeps day-1 UX identical and avoids a
// double-charge if the recurring schedule fires too early.
//
// manifestSnapshot is the frozen production picks (quantity / substrate /
// packagingMaterial / finishes / shipTo) — when the cycle generates an
// Order, we read this snapshot, NOT the latest CheckoutDraft. If the
// creator wants to change the recurring spec they cancel + re-subscribe.
// That gives partners the guarantee that the manifest they accepted
// originally is what they'll see every cycle.
//
// stripeSubscriptionId is the canonical Stripe ID — used for cancel,
// update, and webhook routing. stripePriceId is the snapshot of the
// Stripe Price the subscription bills against (the discount is baked
// into that Price at creation time).

model ProductionSubscription {
  id              String                       @id @default(cuid())
  creatorUserId   String
  brandId         String
  productId       String
  // Locked at subscription creation. Spawned Orders reference this — if
  // the design changes later we keep producing the version the
  // partners accepted.
  designVersionId String?
  cadence         SubscriptionCadence
  // null = open-ended (cancels on explicit cancel). Otherwise the
  // schedule stops after runsCompleted hits totalRuns.
  totalRuns       Int?
  runsCompleted   Int                          @default(0)
  // When the next Stripe invoice will fire — kept in our DB for the
  // /account/subscriptions surface so we don't round-trip Stripe.
  nextRunAt       DateTime?
  // Basis points off the per-run subtotal. 1000 = 10%.
  discountBp      Int                          @default(0)
  // Stripe handles
  stripeSubscriptionId String                  @unique
  stripePriceId        String
  // FSM
  status          ProductionSubscriptionStatus @default(ACTIVE)
  cancelledAt     DateTime?
  cancelledReason String?
  // The frozen production picks (typed in apps/creator wizard).
  // Shape: { quantity, substrateSlug, packagingMaterialSlug,
  //          finishPartnerFinishIds[], shipTo: {...} }
  manifestSnapshot Json
  // Reference subtotal at sign-up — useful for "you locked in $X / run".
  subtotalCentsAtCreation Int
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  // Relations
  creator         User                         @relation("CreatorProductionSubscriptions", fields: [creatorUserId], references: [id])
  brand           Brand                        @relation(fields: [brandId], references: [id])
  product         Product                      @relation(fields: [productId], references: [id])
  // Orders the subscription has spawned. Each cycle creates one.
  orders          Order[]                      @relation("OrdersFromSubscription")

  @@index([creatorUserId, status])
  @@index([nextRunAt])
}

enum SubscriptionCadence {
  MONTHLY
  QUARTERLY
}

enum ProductionSubscriptionStatus {
  ACTIVE       // recurring; next cycle will fire
  PAUSED       // creator paused; no charges until resumed (V1.5)
  CANCELLED    // creator cancelled or Stripe ended billing
  COMPLETED    // hit totalRuns without cancel
}

model Order {
  id                     String         @id @default(cuid())
  brandId                String                                // which brand this batch is produced under
  creatorUserId          String                                // the creator paying iLaunchify
  status                 OrderStatus    @default(PENDING_PAYMENT)
  // Money (in cents) — what the CREATOR pays iLaunchify for this production batch
  subtotalCents          Int                                    // production cost basis (manufacturer cost + label cost)
  shippingCents          Int            @default(0)
  taxCents               Int            @default(0)
  totalCents             Int                                    // subtotal + tax + shipping + platform fee
  // Routing references — chosen partner services
  manufacturerServiceId  String?
  printProviderServiceId String?
  // Ship-to: where the finished goods land after production
  shipToType             OrderShipToType @default(CREATOR_ADDRESS)
  shipToPartnerServiceId String?                                // when shipToType=WAREHOUSE_PARTNER, FK to a WAREHOUSE service
  shipToContactName      String                                 // recipient name on shipping label
  shipToContactPhone     String?
  shipToAddressLine1     String
  shipToAddressLine2     String?
  shipToCity             String
  shipToState            String?
  shipToPostalCode       String
  shipToCountry          String         @default("US")
  // Timestamps
  paidAt                 DateTime?
  deliveredAt            DateTime?
  // Phase H — aggregate approval gate across all OrderDispatch rows.
  // Computed by the FSM on every dispatch transition. Drives the
  // creator's "what's happening" banner + holds Order.status at ROUTING
  // until FULLY_ACCEPTED.
  aggregateApprovalStatus AggregateApprovalStatus @default(AWAITING_PARTNERS)
  // Phase G6 — when this Order was spawned by a recurring subscription
  // cycle, link back to the parent. Null for ordinary one-time orders.
  // The cycle index (which run #N this is) is computed at spawn time
  // and stored separately so the customer-facing surfaces can show
  // "Run 3 of 12" without re-counting siblings.
  productionSubscriptionId String?
  subscriptionCycleNumber  Int?
  // Notes
  internalNotes          String?
  // Relations
  brand                  Brand          @relation(fields: [brandId], references: [id])
  creator                User           @relation("CreatorOrders", fields: [creatorUserId], references: [id])
  shipToPartnerService   PartnerService? @relation("WarehouseShipToOrders", fields: [shipToPartnerServiceId], references: [id])
  productionSubscription ProductionSubscription? @relation("OrdersFromSubscription", fields: [productionSubscriptionId], references: [id])
  items                  OrderItem[]
  dispatches             OrderDispatch[]
  charge                 Charge?
  refunds                Refund[]
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([brandId, status])
  @@index([creatorUserId, status])
}

enum OrderShipToType {
  CREATOR_ADDRESS          // goods ship to the creator's own warehouse / address
  WAREHOUSE_PARTNER        // goods ship to a connected WAREHOUSE partner service
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  unitPriceCents  Int                              // snapshot at order time
  totalCents      Int
  // Phase G8 — locks the exact DesignVersion sold so the production
  // bundle can be regenerated deterministically even after the creator
  // makes further canvas edits. Nullable for legacy orders placed
  // before G8 shipped.
  designVersionId String?
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])
  designVersion   DesignVersion? @relation(fields: [designVersionId], references: [id])
}

// OrderDispatch — one of N dispatches per Order. Per the dual-dispatch model:
// every Order has at least one PRODUCT dispatch (manufacturer) and one LABEL
// dispatch (print provider). They advance independently.
model OrderDispatch {
  id                String           @id @default(cuid())
  orderId           String
  type              DispatchType
  partnerServiceId  String
  status            DispatchStatus   @default(PENDING_ACCEPT)
  // Decline / timeout per docs/USER_ROLES.md decision 2026-05-18
  acceptDeadlineAt  DateTime                          // ASSIGNED + 24h default
  declinedAt        DateTime?
  declineReason     DispatchDeclineReason?
  declineNotes      String?
  rerouteCount      Int              @default(0)
  // Per-state timestamps for the partner workflow (B6).
  // Useful for SLA tracking + audit + partner self-service analytics.
  acceptedAt              DateTime?
  productionStartedAt     DateTime?
  qualityCheckStartedAt   DateTime?
  qualityCheckFailedAt    DateTime?
  qualityCheckFailureNotes String?
  readyAt                 DateTime?
  // Fulfillment
  shippedAt         DateTime?
  inTransitAt       DateTime?
  trackingCarrier   String?
  trackingNumber    String?
  deliveredAt       DateTime?
  // Costs (for transfer reference)
  costCents         Int
  // Phase G8 — production bundle. Manifest is generated synchronously at
  // order placement (substrate / packaging / finishes / die-cut / ship-to
  // — no canvas needed). The actual print-ready PDF + die-line SVG land
  // in V1.5 (a headless-browser worker reads designVersionId on the
  // OrderItem and renders the Fabric JSON). bundleStatus tracks that
  // future workflow.
  bundleStatus       BundleStatus     @default(PENDING_GENERATION)
  finishManifestJson Json?
  bundleAssetId      String?
  bundleGeneratedAt  DateTime?
  // Phase H — manifest version this dispatch is bound to. Starts at 1.
  // Increments when a CHANGES_REQUESTED adjustment ships a new snapshot.
  // The partner's ACCEPTED row records the version they accepted; if it
  // doesn't match the current row, the partner sees a 're-review' banner.
  manifestVersion    Int              @default(1)
  acceptedManifestVersion Int?
  // Phase H — when status is CHANGES_REQUESTED, carries the structured
  // payload partners filed. Shape:
  //   { flaggedFields: string[], partnerNote: string,
  //     suggestedAlternatives: Record<string, string|null>,
  //     requestedAt: ISO }
  changeRequest      Json?
  // Phase H — Partner withdrew after acceptance — reason + ISO. Distinct
  // from declineReason because the lifecycle stage is different.
  withdrawnAt        DateTime?
  withdrawReason     String?
  // Relations
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  partnerService    PartnerService   @relation(fields: [partnerServiceId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([orderId])
  @@index([partnerServiceId, status])
}

// =============================================================================
// PAYMENTS (Stripe Connect)
// =============================================================================

model Charge {
  id                  String        @id @default(cuid())
  orderId             String        @unique
  stripeChargeId      String        @unique
  stripePaymentIntentId String
  amountCents         Int
  currency            String        @default("usd")
  applicationFeeCents Int                                  // platform's cut (withheld at charge time)
  status              ChargeStatus
  statementDescriptor String?
  // Relations
  order               Order         @relation(fields: [orderId], references: [id])
  transfers           Transfer[]
  refunds             Refund[]
  dispute             Dispute?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Transfer {
  id                  String              @id @default(cuid())
  chargeId            String
  destinationStripeId String
  destinationUserId   String
  destinationType     TransferDestination
  amountCents         Int
  reason              TransferReason
  stripeTransferId    String?             @unique
  status              TransferStatus      @default(PENDING)
  scheduledFor        DateTime?
  executedAt          DateTime?
  failureReason       String?
  reversedByRefundId  String?
  // Relations
  charge              Charge              @relation(fields: [chargeId], references: [id])
  destinationUser     User                @relation("TransferDestinationUser", fields: [destinationUserId], references: [id])
  reversedByRefund    Refund?             @relation(fields: [reversedByRefundId], references: [id])
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([status, scheduledFor])
  @@index([chargeId])
}

model Refund {
  id                  String       @id @default(cuid())
  chargeId            String
  orderId             String
  stripeRefundId      String       @unique
  amountCents         Int
  reason              RefundReason
  status              RefundStatus @default(PENDING)
  initiatedByUserId   String
  // Relations
  charge              Charge       @relation(fields: [chargeId], references: [id])
  order               Order        @relation(fields: [orderId], references: [id])
  initiatedByUser     User         @relation(fields: [initiatedByUserId], references: [id])
  clawbacks           PartnerClawback[]
  reversedTransfers   Transfer[]
  createdAt           DateTime     @default(now())
}

model Dispute {
  id                  String          @id @default(cuid())
  chargeId            String          @unique
  stripeDisputeId     String          @unique
  amountCents         Int
  reason              String
  status              DisputeStatus   @default(NEEDS_RESPONSE)
  evidenceDueBy       DateTime
  evidenceSubmittedAt DateTime?
  resolvedAt          DateTime?
  outcome             String?
  // Relations
  charge              Charge          @relation(fields: [chargeId], references: [id])
  clawbacks           PartnerClawback[]
  createdAt           DateTime        @default(now())
}

// =============================================================================
// CART & CONSUMER — REMOVED 2026-05-19
// =============================================================================
// The Cart, CartItem, and ConsumerUser models were removed when the V1 model
// was corrected. iLaunchify is a B2B production marketplace; consumers do not
// buy on iLaunchify — they buy on the creator's external channel (Shopify,
// Amazon, etc.). See docs/STOREFRONT.md.
// =============================================================================

// =============================================================================
// CATALOG: Category → Subcategory → ProductTemplate → Variant + Ingredient Slots
// =============================================================================
// The catalog is the front of the creator funnel. Admin curates ProductTemplates
// per (Sub)category. Each template has BASE ingredient slots — each slot is the
// manufacturer's default ingredient, plus an optional list of allowed
// replacements. Independently, the template offers a pool of OPTIONAL
// ingredients the creator can toggle on. Variants (flavor + packaging combos)
// are orthogonal to ingredients — same recipe, different flavor + bottle size.
// =============================================================================

// ProductTemplate lifecycle per docs/MANUFACTURER_PRODUCT_BUILDER.md §8.1.
// Legacy 4-value enum extended with 5 V1 canonical states. Legacy values are
// preserved for back-compat with rows created before 2026-05-24.
//
// Canonical FSM:
//   DRAFT → PENDING_REVIEW ─Approve─→ PUBLISHED
//                          ─Request changes─→ NEEDS_CHANGES ─Resubmit─→ PENDING_REVIEW
//                          ─Reject─→ REJECTED
//   PUBLISHED ─edit approval-marked field─→ PENDING_EDIT_REVIEW ─Approve─→ PUBLISHED
//   PUBLISHED / PENDING_EDIT_REVIEW ⇄ PAUSED (admin or partner)
//
// Legacy mapping (for back-compat when reading older rows):
//   UNDER_REVIEW → PENDING_REVIEW
//   ARCHIVED     → REJECTED (semantically closest; admin can re-classify)
enum ProductTemplateStatus {
  // V1 canonical (from 2026-05-24 forward)
  DRAFT                  // manufacturer authoring (same as legacy)
  PENDING_REVIEW         // admin queue (first submission of a never-published template)
  NEEDS_CHANGES          // admin requested changes via ProductReviewItem checklist
  PUBLISHED              // visible in /catalog (same as legacy)
  PENDING_EDIT_REVIEW    // changes to a live published template held for admin approval; live version keeps serving
  PAUSED                 // hidden from marketplace (admin or partner initiated); reversible
  REJECTED               // admin rejected; partner can resubmit as new submission
  // Legacy (deprecated; preserved for back-compat)
  UNDER_REVIEW           // alias for PENDING_REVIEW
  ARCHIVED               // alias for REJECTED
}

// =============================================================================
// PACKING TOPOLOGY
// =============================================================================
// One axis is *what's inside* the product (ingredient slots + variants for
// flavor). A second, orthogonal axis is *how it's packaged*: a single can, a
// 6-pack, a sampler box, a customer-picked variety set, a subscription delivery.
//
// Per Pavel's spec, 14 packing types are needed at V1 to describe every product
// SKU type the platform serves. Each ProductTemplateVariant declares one
// PackingType plus structured fields that describe the topology (how many inner
// packs, mixed vs. separated flavor arrangement, customer-pick parameters,
// subscription cadence). The remainder lives in `packingConfig` JSON.
// =============================================================================

enum PackingType {
  SINGLE_FLAVOR_SINGLE_PACK         // 1 can of cola, 1 jar of apple puree
  SINGLE_FLAVOR_MULTIPACK           // 6-pack same flavor, 12-pack same flavor
  MULTI_FLAVOR_MIXED_PACK           // fruit-salad gummies (all flavors in one bag)
  MULTI_FLAVOR_COMPARTMENT_PACK     // chocolate bar with milk/white/dark sections
  MULTI_FLAVOR_INDIVIDUAL_IN_OUTER  // variety ramen 4-pack (each flavor in own bag, in one box)
  CUSTOMIZABLE_PICK_N               // pick 6 of 24 beer flavors; pick 10 protein bars from 5 flavors
  SAMPLER_MINI                      // mini hot-sauce sampler (5 small bottles, different flavors)
  SUBSCRIPTION_ROTATING             // monthly coffee, rotating flavors
  GIFT_PREMIUM                      // luxury chocolate box, gourmet gift tin
  VALUE_BULK_SINGLE                 // 50-pack same flavor, 10kg bag dog food
  VALUE_BULK_VARIETY                // 10 variety packs each with 3 flavors (bulk)
  SEASONAL_LIMITED                  // pumpkin spice set, Christmas dog treats
  PAIRING_FUNCTIONAL                // coffee + creamer set, pre + post-workout
  RETAIL_COUNTER_DISPLAY            // counter tray, clip strip — one SKU for retailer
  REFILL_ECO                        // reusable container + replaceable concentrates
}

enum FlavorArrangement {
  SINGLE         // one flavor (or unflavored)
  MIXED          // flavors blended/scattered in the same vessel
  SEPARATED      // flavors physically separated (compartments, individual inner packs)
}

model Category {
  id              String        @id @default(cuid())
  externalId      String        @unique          // imported from FOD: 1c513f19-…
  name            String                          // "Snacks & Confectionery"
  slug            String        @unique
  description     String?
  mainCategory    String                          // "Food" | "Beverages" | "Supplements" | "Other"
  icon            String?                         // emoji or short string
  color           String?                         // hex
  displayOrder    Int           @default(0)
  isActive        Boolean       @default(true)
  // Regulatory hooks — which rule pack applies + required label elements
  regulatoryRequirements Json?
  designRestrictions     Json?
  subcategories   Subcategory[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Subcategory {
  id              String        @id @default(cuid())
  externalId      String        @unique
  categoryId      String
  name            String
  slug            String        @unique
  description     String?
  displayOrder    Int           @default(0)
  isActive        Boolean       @default(true)
  // Packaging defaults (sizes, materials, container types) — informs variants
  packagingOptions Json?
  category        Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  productTemplates ProductTemplate[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  @@index([categoryId])
}

model ProductTemplate {
  id              String        @id @default(cuid())
  subcategoryId   String
  manufacturerServiceId String?                          // null until manufacturer self-builder ships (V1.1)
  status          ProductTemplateStatus  @default(DRAFT)
  name            String                                  // "Whey Protein Powder"
  description     String?
  slug            String        @unique
  // Price floor — lowest the creator can list at (covers manuf cost + print + fee + margin floor)
  priceFloorCents Int           @default(0)
  // Estimated unit cost to platform (manuf's price for one base unit) — used by routing
  unitCostCents   Int           @default(0)
  imageAssetId    String?
  // Optional: snapshot of base nutrition (BASE ingredients only) for fast catalog display
  baseNutritionSnapshot Json?
  // V1 — per docs/MANUFACTURER_PRODUCT_BUILDER.md
  pendingEditPayload          Json?                       // proposed edits while in PENDING_EDIT_REVIEW; live row keeps serving
  finishedProductWeightG      Int?                        // derived from slots; cached for shipping calc
  customMeta                  Json?                       // partner-supplied key/value pairs ([{key,value}] max 10)
  allergenCrossContamination  String?                     // partner-input cross-contamination statement
  allergenManualOverrides     Json?                       // [{ allergen, reason }] for manual additions
  // V1 — Recipal-parity additions per docs/MANUFACTURER_PRODUCT_BUILDER.md §4a.5c + §4a.5d
  nutrientOverrides           Json?                       // [{ nutrient, value, reason }] — applied after sum, before rounding
  ingredientGroups            Json?                       // [{ groupName, ingredientIds[], displayMode, sortAs }] for FDA-allowed grouping ('Spices', 'Natural Flavors')
  // Relations
  subcategory     Subcategory   @relation(fields: [subcategoryId], references: [id])
  manufacturerService PartnerService? @relation(fields: [manufacturerServiceId], references: [id])
  ingredientSlots TemplateIngredientSlot[]
  optionalIngredients TemplateOptionalIngredient[]
  variants        ProductTemplateVariant[]
  products        Product[]
  // V1 new relations (manufacturer product builder)
  packagingSystems ProductTemplatePackaging[]
  certificates    ProductCertificate[]
  reviewItems     ProductReviewItem[]
  notes           ProductNote[]
  flavorPresets   FlavorPreset[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  @@index([subcategoryId, status])
}

// One slot per BASE ingredient. The base is the default; replacements[] are
// alternatives the creator can swap in.
model TemplateIngredientSlot {
  id              String        @id @default(cuid())
  productTemplateId String
  baseIngredientId  String                                 // default ingredient
  weightG         Decimal                                  // grams in the base recipe (per batch)
  displayOrder    Int           @default(0)
  // Manufacturer can lock specific slots from replacement (e.g. structural fillers)
  allowReplacement Boolean      @default(true)
  // Display hints
  label           String?                                  // optional override of the ingredient name in UI
  description     String?
  // Relations
  productTemplate ProductTemplate @relation(fields: [productTemplateId], references: [id], onDelete: Cascade)
  baseIngredient  Ingredient    @relation("SlotBaseIngredient", fields: [baseIngredientId], references: [id])
  replacements    TemplateIngredientReplacement[]
  filledByRecipeIngredients RecipeIngredient[]            // back-relation for source tracking
  @@index([productTemplateId])
}

model TemplateIngredientReplacement {
  id              String        @id @default(cuid())
  slotId          String
  ingredientId    String                                   // the swap option
  // Optional weight override (e.g., monk fruit at 1g replaces sugar at 30g for equivalent sweetness)
  weightGOverride Decimal?
  displayOrder    Int           @default(0)
  // Display hints
  calloutText     String?                                  // "Lower glycemic alternative"
  // Relations
  slot            TemplateIngredientSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  ingredient      Ingredient    @relation("ReplacementIngredient", fields: [ingredientId], references: [id])
  @@unique([slotId, ingredientId])
  @@index([slotId])
}

// Independent pool of ingredients the creator can OPTIONALLY add.
// Toggled on/off as a whole — no per-creator weight tweaking in V1.
model TemplateOptionalIngredient {
  id              String        @id @default(cuid())
  productTemplateId String
  ingredientId    String
  weightG         Decimal                                  // grams added when toggled on
  displayOrder    Int           @default(0)
  calloutText     String?                                  // "Adds 200mg L-Theanine for calm focus"
  productTemplate ProductTemplate @relation(fields: [productTemplateId], references: [id], onDelete: Cascade)
  ingredient      Ingredient    @relation("OptionalIngredient", fields: [ingredientId], references: [id])
  @@unique([productTemplateId, ingredientId])
  @@index([productTemplateId])
}

// One row per sellable SKU configuration: a particular combination of flavor
// content + container + packing topology. The same ProductTemplate can offer
// (Tropical Citrus 12oz single can), (6-pack of Tropical), (mixed 6-pack
// 3×Tropical+3×Berry), (pick-12-from-24 customizable case), etc. — each a
// distinct variant.
model ProductTemplateVariant {
  id              String        @id @default(cuid())
  productTemplateId String

  // ---- Flavor + container (the consumed product) ----
  flavor          String?                                  // "Vanilla" / "Chocolate" — null for unflavored or multi-flavor
  containerFormat String                                   // "12oz can" / "60-count capsule bottle" / "250g pouch"
  containerSizeG  Decimal?                                 // total contents weight inside one container
  servingsPerContainer Int
  servingSizeG    Decimal                                  // grams per serving
  servingSizeDesc String?                                  // "1 scoop (30g)"

  // ---- Packing topology (orthogonal to flavor/container) ----
  packingType         PackingType        @default(SINGLE_FLAVOR_SINGLE_PACK)
  flavorArrangement   FlavorArrangement  @default(SINGLE)
  // Number of INDIVIDUAL packs inside one sellable outer pack (a 6-pack = 6).
  // 1 = single pack (no outer). For VARIETY_BULK use innerPacksPerOuter for the
  // inner-pack count and outerPacksPerCase for the case count.
  innerPacksPerOuter  Int                @default(1)
  outerPacksPerCase   Int                @default(1)
  // CUSTOMIZABLE_PICK_N: consumer picks `customerPicksCount` flavors from a pool
  // (the pool is the set of sibling variants of the same template).
  customerPicksCount  Int?
  // SUBSCRIPTION_ROTATING: "monthly", "weekly", "quarterly"
  subscriptionInterval String?
  // For MULTI_FLAVOR_MIXED / SEPARATED / SAMPLER / VARIETY_BULK / SEASONAL etc:
  // structured list of contained flavors with per-flavor quantities.
  // Example: [{"flavor":"Vanilla","qty":2},{"flavor":"Chocolate","qty":4}]
  assortmentFlavors   Json?
  // Free-form extras (retail-display dimensions, refill-pod ml, etc.)
  packingConfig       Json?

  // ---- Commercial ----
  moqMin          Int           @default(500)
  moqMax          Int           @default(5000)
  leadTimeDays    Int           @default(28)
  // Per-variant cost override (a 6-pack costs more than a single can to produce)
  unitCostCentsOverride Int?

  // ---- Visual ----
  dieCutTemplateId String?
  isActive        Boolean       @default(true)

  // Relations
  productTemplate ProductTemplate @relation(fields: [productTemplateId], references: [id], onDelete: Cascade)
  dieCutTemplate  DieCutTemplate? @relation(fields: [dieCutTemplateId], references: [id])
  products        Product[]
  createdAt       DateTime      @default(now())
  @@index([productTemplateId, isActive])
  @@index([packingType])
}

// ============================================================================
// Phase A — Verification + Files + Audit Log
// See docs/FOD_RECOVERY_PLAN.md §6 for context.
// ============================================================================

// 4-section verification model (per Pavel decision 2026-05-19, keeping FOD's
// taxonomy). Each section is independently reviewed by an admin with notes;
// overall Partner.status is computed from the section statuses:
//   - any REJECTED      → Partner.status = SUSPENDED (admin manual)
//   - any NEEDS_CHANGES → Partner.status = IN_PROGRESS (partner must fix)
//   - all VERIFIED      → Partner.status = ACTIVE (admin manual approve)
//   - else              → Partner.status = UNDER_REVIEW (initial submit)
enum VerificationSectionType {
  BUSINESS               // Legal name, registration, EIN/VAT, addresses, KYB
  FACILITY               // Production capabilities, certifications, MOQ, lead time
  DOCUMENTS              // Uploaded compliance docs (license, insurance, cert PDFs)
  PUBLIC_PROFILE         // Public-facing brand info (logo, description, badges)
  OPERATIONAL_STANDARDS  // 5-section model addition per docs/PARTNER_ONBOARDING.md §5 + #159
}

enum VerificationSectionStatus {
  PENDING          // Not yet reviewed
  VERIFIED         // Approved by admin
  NEEDS_CHANGES    // Admin requested edits; partner can resubmit this section
  REJECTED         // Permanently rejected (rare; usually leads to suspension)
}

model PartnerVerificationSection {
  id            String                     @id @default(cuid())
  partnerId     String
  type          VerificationSectionType
  status        VerificationSectionStatus  @default(PENDING)
  adminNotes    String?                    // Internal note shown to partner verbatim
  verifiedAt    DateTime?
  verifiedById  String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  partner       Partner                    @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  verifiedBy    User?                      @relation("VerificationSectionVerifier", fields: [verifiedById], references: [id])
  files         PartnerFile[]              // files attached to this section

  @@unique([partnerId, type])              // exactly one row per (partner, section)
  @@index([status])
}

// Partner-uploaded files, stored on R2 (per Pavel decision 2026-05-19).
// The r2Key is the canonical storage path; we generate signed URLs on read.
// Files are grouped by sectionType so the admin verification queue can show
// "all DOCUMENTS-section files for this partner" in one place.
enum PartnerFileKind {
  CERTIFICATE              // ISO, BRC, SQF, organic, kosher, etc.
  BUSINESS_LICENSE
  INSURANCE
  FACILITY_PHOTO
  LOGO
  KYB_ID                   // Beneficial owner ID (driver's license, passport)
  CERT_OF_INCORPORATION
  PRODUCT_SAMPLE           // For verification (photos of finished goods)
  OTHER
}

model PartnerFile {
  id               String                       @id @default(cuid())
  partnerId        String
  sectionType      VerificationSectionType      // which verification section this file belongs to
  sectionId        String?                      // optional FK to the specific PartnerVerificationSection row
  kind             PartnerFileKind
  r2Key            String                       @unique  // bucket-relative path
  originalFilename String
  contentType      String                       // MIME type
  sizeBytes        Int
  uploadedById     String                       // who uploaded (partner user)
  uploadedAt       DateTime                     @default(now())

  partner          Partner                      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  section          PartnerVerificationSection?  @relation(fields: [sectionId], references: [id])
  uploadedBy       User                         @relation("PartnerFileUploader", fields: [uploadedById], references: [id])

  @@index([partnerId, sectionType])
  @@index([partnerId, kind])
}

// AuditLog — every state transition on User, Partner, PartnerService, Order,
// OrderDispatch, etc. Per Pavel decision 2026-05-19, system-driven transitions
// (Stripe webhooks, scheduled cron) log with actorRole=SYSTEM so we have a
// complete forensic trail.
//
// Writers should use logAudit() from @ilaunchify/audit rather than touching this
// model directly — that helper handles actor resolution + payload serialization.
enum AuditActorRole {
  ADMIN
  CREATOR
  PARTNER
  SYSTEM           // Webhook handlers, cron jobs, migrations
}

model AuditLog {
  id           String          @id @default(cuid())
  actorId      String?         // null when actorRole=SYSTEM
  actorRole    AuditActorRole
  // Entity identification
  entityType   String          // "Partner" / "OrderDispatch" / "PartnerVerificationSection" etc.
  entityId     String          // the affected row's id
  // What happened
  action       String          // "ACTIVATE" / "SUSPEND" / "VERIFY_SECTION" / "MARK_SHIPPED" etc.
  fromValue    String?         // previous state when applicable (status enum value, etc.)
  toValue      String?         // new state when applicable
  // Free-form context — sources can stash anything (decline reason, admin notes, etc.)
  payload      Json?
  at           DateTime        @default(now())

  actor        User?           @relation("AuditLogActor", fields: [actorId], references: [id])

  @@index([entityType, entityId, at])    // history for a single entity
  @@index([actorId, at])                 // what did this user do
  @@index([at])                          // time-range queries
}

// ============================================================================
// Phase B — Notifications
// See docs/FOD_RECOVERY_PLAN.md §4 (B1).
// ============================================================================

// Channels users can receive notifications on. EMAIL goes through Resend;
// IN_APP is the bell/notification center inside the app.
enum NotificationChannel {
  EMAIL
  IN_APP
}

// V1 event taxonomy — keep small and meaningful. Each maps to a templated
// title + body in packages/notifications/src/templates.ts.
enum NotificationEvent {
  // Partner-facing
  SECTION_VERIFIED            // admin approved one of their verification sections
  SECTION_NEEDS_CHANGES       // admin requested partner edit a section
  PARTNER_ACTIVATED           // welcome / fully approved
  DISPATCH_RECEIVED           // new order dispatch needs partner action
  DISPATCH_ACCEPT_REMINDER    // accept window is closing soon (defer to V1.1)
  // Phase H4 — creator-facing workflow events
  CREATOR_DISPATCH_ACCEPTED       // a partner accepted one of the creator's dispatches
  CREATOR_DISPATCH_CHANGES_REQUESTED // partner filed structured change request
  CREATOR_DISPATCH_DECLINED       // partner declined (auto-reroute in progress for non-manufacturer)
  CREATOR_DISPATCH_WITHDRAWN      // partner withdrew after acceptance
  CREATOR_ORDER_FULLY_ACCEPTED    // all partners signed off → production starting
  CREATOR_ORDER_CANCELLED_BY_MANUFACTURER // manufacturer reject = order killed
  // Admin-facing
  PARTNER_APPLIED             // new lead arrived
  PARTNER_SUBMITTED           // partner finished onboarding, ready for review
  ORDER_NEEDS_ATTENTION       // order moved to ON_HOLD / DISPUTED (defer to V1.1)
  // Phase H4 — admin needs visibility on manufacturer-cancel + withdrawal
  ADMIN_ORDER_CANCELLED_BY_MANUFACTURER
  ADMIN_DISPATCH_WITHDRAWN
}

// One row per delivered (or queued) notification, per channel. EMAIL and IN_APP
// each get their own row so we can independently track read state vs. send state.
model Notification {
  id           String              @id @default(cuid())
  userId       String
  event        NotificationEvent
  channel      NotificationChannel
  // Display
  title        String                                          // e.g. "Acme Foods approved"
  body         String?                                         // longer description
  link         String?                                         // app-relative URL (e.g. "/my-application")
  // Channel-specific state
  emailSentAt  DateTime?                                       // when Resend confirmed send
  emailError   String?                                         // truncated error if send failed
  readAt       DateTime?                                       // in-app read state
  // Free-form context (entity ids the receiver may want to navigate to)
  payload      Json?
  createdAt    DateTime            @default(now())

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])                                    // unread feed query
  @@index([userId, createdAt])                                 // chronological feed
  @@index([event])
}

// Per-user per-event per-channel opt-out. Default: enabled. Rows are upserted
// only when the user explicitly toggles a preference; absent rows are treated
// as enabled by the dispatcher.
model NotificationPreference {
  id       String              @id @default(cuid())
  userId   String
  event    NotificationEvent
  channel  NotificationChannel
  enabled  Boolean             @default(true)
  updatedAt DateTime           @updatedAt

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, event, channel])
}

// ============================================================================
// CHANNELS — V1 shell, V1.1+ adds real OAuth + listing push
// ============================================================================
// Per the 2026-05-19 model correction, iLaunchify is a B2B production
// platform. After production is delivered, creators push finished SKUs to
// their external sales channels (Shopify, Amazon, Etsy, etc.) for consumer
// purchases. V1 ships these models + an admin toggle UI so the registry
// exists; the real OAuth flow + Push-to-Channel actions land in V1.1+.

// Admin-managed registry. One row per channel iLaunchify supports.
// Admin sets `enabled` to expose a channel in creator UI; toggling off
// hides it for new connections (existing ChannelConnections remain).
model Channel {
  id              String   @id @default(cuid())
  code            String   @unique           // "shopify", "amazon", "woocommerce", "etsy", "walmart", "tiktok"
  displayName     String                     // human-facing label
  logoUrl         String?
  enabled         Boolean  @default(false)
  // True once the platform-level OAuth app credentials are set in env
  // (Shopify Client ID/Secret, Amazon SP-API creds, etc.). Until true,
  // the channel can be enabled but creators can't actually connect.
  oauthConfigured Boolean  @default(false)
  // Free-form notes admin can leave for ops
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  // Relations
  connections     ChannelConnection[]
  productLinks    ChannelProductLink[]
}

// Per-creator OAuth connection to one channel. V1: row exists only as
// a placeholder; access/refresh tokens are not yet populated. V1.1 adds
// the OAuth flow that fills these.
model ChannelConnection {
  id             String   @id @default(cuid())
  channelId      String
  creatorUserId  String
  // External account identifier (shop domain for Shopify, seller_id for Amazon, etc.)
  externalAccountId String?
  // OAuth tokens (V1.1+) — referenced by handle, not stored raw here
  accessTokenRef  String?                    // pointer to secret store
  refreshTokenRef String?
  scopes          String[]                   @default([])
  status          ChannelConnectionStatus    @default(NOT_CONNECTED)
  connectedAt     DateTime?
  disconnectedAt  DateTime?
  lastSyncAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  // Relations
  channel         Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  creator         User    @relation("CreatorChannelConnections", fields: [creatorUserId], references: [id], onDelete: Cascade)
  productLinks    ChannelProductLink[]

  @@unique([channelId, creatorUserId])       // one connection per (channel, creator)
}

enum ChannelConnectionStatus {
  NOT_CONNECTED                              // placeholder row before OAuth
  CONNECTED                                  // active, tokens valid
  TOKEN_EXPIRED                              // needs reconnect
  DISCONNECTED                               // creator revoked
  ERROR                                      // last sync failed
}

// Per-product → external listing mapping. Created when a creator clicks
// "Push to channel" for a delivered product. The external listing id is
// what the channel returned after creating the listing.
model ChannelProductLink {
  id                 String   @id @default(cuid())
  channelId          String
  channelConnectionId String
  productId          String
  externalListingId  String                   // Shopify product_id, Amazon ASIN, etc.
  externalUrl        String?                  // direct link to the listing
  status             ChannelProductLinkStatus @default(ACTIVE)
  lastPushedAt       DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  // Relations
  channel            Channel           @relation(fields: [channelId], references: [id])
  channelConnection  ChannelConnection @relation(fields: [channelConnectionId], references: [id], onDelete: Cascade)
  product            Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([channelId, productId])           // one link per (channel, product)
  @@index([channelConnectionId])
}

enum ChannelProductLinkStatus {
  ACTIVE                                     // listing live on the channel
  ARCHIVED                                   // unpublished from the channel
  ERROR                                      // last push failed
}

// =============================================================================
// MARKETS & REGIONS — V1 (US-only ACTIVE; CA seeded COMING_SOON; EU V2)
// Spec: docs/MARKETS_AND_REGIONS.md
// =============================================================================
//
// Two distinct concepts:
//   Market = regulatory + commercial jurisdiction (drives label rules, allergen
//            policy, language requirements, currency, rule pack selection)
//   Region = physical location (drives shipping, lead time, partner-proximity
//            matching, freight zones)
//
// V1 seed:
//   - 1 ACTIVE Market: "US" (FDA)
//   - 1 COMING_SOON Market: "CA" (CFIA, hidden from selection)
//   - 1 Language: "en-US"
//   - Region tree: 1 country (US) + 5 sub-regions (NE/SE/MW/SW/NW per Census)
//     + 50 STATE_PROVINCE rows linked to parent sub-regions

enum MarketStatus {
  ACTIVE                                     // selectable by partners/brands; products can target it
  COMING_SOON                                // seeded but hidden from selection (admin can preview)
  DEPRECATED                                 // no new selections; existing relations preserved
}

enum RegionKind {
  COUNTRY                                    // 'US', 'CA'
  SUBNATIONAL_GROUP                          // 'US-NE', 'US-SE' (Census Bureau divisions)
  STATE_PROVINCE                             // 'US-CA', 'US-NY' (or CA provinces)
  METRO                                      // V1.1+ — major metro areas for finer proximity
}

enum PartnerMarketStatus {
  ACTIVE                                     // certification verified, in date
  LAPSED                                     // expired; partner notified, soft-suspended for this market
  REVOKED                                    // admin revoked; permanent
}

// -----------------------------------------------------------------------------
// Language + MarketLanguage — supports bilingual jurisdictions (CFIA EN+FR)
// -----------------------------------------------------------------------------

model Language {
  id              String           @id                    // 'en-US', 'fr-CA', 'es-MX'
  code            String                                  // 'en', 'fr', 'es'
  name            String                                  // 'English (US)'
  region          String?                                 // 'US', 'CA'
  isActive        Boolean          @default(true)
  marketLinks     MarketLanguage[]
  defaultIn       Market[]         @relation("DefaultLanguage")
}

model MarketLanguage {
  id              String           @id @default(cuid())
  marketId        String
  languageId      String
  isDefault       Boolean          @default(false)
  isRequired      Boolean          @default(false)        // CFIA Canada requires EN+FR
  displayOrder    Int              @default(0)
  market          Market           @relation(fields: [marketId], references: [id], onDelete: Cascade)
  language        Language         @relation(fields: [languageId], references: [id], onDelete: Cascade)
  @@unique([marketId, languageId])
}

// -----------------------------------------------------------------------------
// MarketConfig — key/value extensions per market (number_format, date_format,
//                weight_unit_default, etc.)
// -----------------------------------------------------------------------------

model MarketConfig {
  id              String           @id @default(cuid())
  marketId        String
  key             String                                  // 'number_format', 'date_format'
  value           Json
  market          Market           @relation(fields: [marketId], references: [id], onDelete: Cascade)
  @@unique([marketId, key])
}

// -----------------------------------------------------------------------------
// Region — geographic tree (country → subnational group → state/province →
//          metro V1.1+). Each region belongs to one Market.
// -----------------------------------------------------------------------------

model Region {
  id               String     @id @default(cuid())
  code             String     @unique                     // 'US', 'US-NE', 'US-CA', 'US-NYC'
  name             String                                 // 'California', 'Northeast US'
  marketId         String
  parentRegionId   String?                                 // 'US-NE' is parent of 'US-NY'
  kind             RegionKind
  centroidLatLng   Json?                                   // { lat, lng } for distance math
  shippingZone     String?                                 // freight-zone identifier
  isActive         Boolean    @default(true)
  market           Market     @relation(fields: [marketId], references: [id])
  parent           Region?    @relation("RegionTree", fields: [parentRegionId], references: [id])
  children         Region[]   @relation("RegionTree")
  partnersAtRegion Partner[]  @relation("PartnerPrimaryRegion")
  brandsOperating  Brand[]    @relation("BrandOperatingRegion")
  @@index([marketId, kind])
}

// -----------------------------------------------------------------------------
// PartnerMarketCert — which markets a partner is certified to produce for,
//                     with cert ref + expiry. Admin verifies in Vendor
//                     Verification queue (#94 extension #159).
// -----------------------------------------------------------------------------

model PartnerMarketCert {
  partnerId        String
  marketId         String
  certifiedAt      DateTime
  expiresAt        DateTime?
  certificationRef String?                                 // FDA registration #, Health Canada licence #
  status           PartnerMarketStatus @default(ACTIVE)
  partner          Partner            @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  market           Market             @relation(fields: [marketId], references: [id])
  @@id([partnerId, marketId])
  @@index([marketId, status])
}

// -----------------------------------------------------------------------------
// BrandTargetMarket — which markets a brand sells into. First-written is
//                     marked isPrimary for default labelling.
// -----------------------------------------------------------------------------

model BrandTargetMarket {
  brandId    String
  marketId   String
  isPrimary  Boolean @default(false)
  brand      Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  market     Market  @relation(fields: [marketId], references: [id])
  @@id([brandId, marketId])
  @@index([marketId])
}

// =============================================================================
// PARTNER 5-LAYER ONBOARDING — V1
// Spec: docs/PARTNER_ONBOARDING.md
// =============================================================================
//
// The 5 layers (each independent, non-sequential after Identity):
//   L1 Identity & Verification    — Phase A model (PartnerVerificationSection 4 sections + 5th OPERATIONAL_STANDARDS)
//   L2 Operational Capability     — structured productTypes / packagingFormats / specs / MOQ / lead time / specialties
//   L3 Operational Standards      — partner-wide: response SLA, comm channel, escalation, revisions
//   L4 Financial & Commercial     — fixed STANDARD_V1.0 contract for V1; per-partner override via contractOverrideId V1.5+
//   L5 System Integration         — dashboard-only baseline; CSV/webhook/API hooks reserved
//
// Activation FSM (PartnerStatus enum above): LEAD → IDENTITY_PENDING_REVIEW
//   → IDENTITY_VERIFIED → OPS_PENDING_REVIEW → OPERATIONALLY_CONFIGURED → ACTIVE
//   → (INTEGRATION_ENHANCED) + side states PAUSED / SUSPENDED / TERMINATED.

// -----------------------------------------------------------------------------
// LAYER 2 — Operational Capability
// -----------------------------------------------------------------------------

model PartnerOperationalCapability {
  id                   String   @id @default(cuid())
  partnerId            String   @unique
  // Controlled vocabularies (admin-managed; values validated in app layer for V1)
  productTypes         String[]                              // e.g., ['carbonated_beverage', 'supplement_powder', 'hot_sauce']
  packagingFormats     String[]                              // e.g., ['12oz_slim_can', '16oz_pet_bottle']
  productionSpecs      String[]                              // e.g., ['hot_fill', 'cold_fill', 'HPP', 'pasteurization']
  // Quantitative
  moqUnitsMin          Int                                   // typical minimum order qty floor
  moqUnitsTypical      Int                                   // most common MOQ partners quote
  leadTimeDaysMin      Int                                   // typical lead time window low end
  leadTimeDaysMax      Int                                   // typical lead time window high end
  monthlyCapacityUnits Int?                                  // optional production ceiling per month
  // Specialty boost — subset of productTypes the partner is best at;
  // drives marketplace ranking (per docs/MARKETS_AND_REGIONS.md matching).
  specialties          String[]
  notes                String?                               // partner-supplied free-text caveats
  updatedAt            DateTime @updatedAt
  partner              Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// LAYER 3 — Operational Standards (partner-wide V1; per-product override V1.5+)
// -----------------------------------------------------------------------------

enum CommChannel {
  EMAIL
  IN_APP
  PHONE
}

enum RevisionPolicy {
  PLATFORM_DEFAULT      // V1 default — uses PlatformMandatedStandards rules
  CUSTOM_NEGOTIATED     // V1.5+ admin-mediated per-partner negotiated terms
}

enum ProductionConfirmationMode {
  SLOW_CONFIRM          // 24h email loop (default for non-integrated partners)
  FAST_CONFIRM          // in-app, immediate (requires partner to be active in dashboard)
}

model PartnerOperationalStandards {
  id                          String                     @id @default(cuid())
  partnerId                   String                     @unique
  responseTimeHours           Int                        @default(24)   // partner commits to respond to new orders within X hours
  preferredCommChannel        CommChannel                @default(IN_APP)
  escalationContact           Json                                       // { name, email, phone, role }
  revisionPolicy              RevisionPolicy             @default(PLATFORM_DEFAULT)
  customRevisionTerms         String?                                    // only set when revisionPolicy=CUSTOM_NEGOTIATED
  productionConfirmationMode  ProductionConfirmationMode @default(SLOW_CONFIRM)
  acceptedDefaults            Boolean                    @default(true)  // convenience flag — "partner accepted all V1 defaults"
  updatedAt                   DateTime                   @updatedAt
  partner                     Partner                    @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

// Singleton — platform-wide standards applied to ALL partners.
// Admin-edited via /admin/platform-settings/operational-standards.
// Versioned for audit (append-only; never edit existing rows).
model PlatformMandatedStandards {
  id                           String   @id @default(cuid())
  version                      String   @unique                          // 'v1.0', 'v1.1'
  acceptedArtworkFormats       String[] @default(["AI", "PDF", "SVG", "PSD"])
  versioningRule               String   @default("every_change_new_version")
  disputeResolutionWindowDays  Int      @default(14)
  escalationPath               Json                                       // tier sequence: tier1 admin → tier2 admin → legal
  effectiveFrom                DateTime
  effectiveTo                  DateTime?
  createdAt                    DateTime @default(now())
}

// -----------------------------------------------------------------------------
// LAYER 4 — Financial & Commercial
// Fixed standard contract V1; per-partner override hook reserved for V1.5+.
// -----------------------------------------------------------------------------

enum ContractStatus {
  DRAFT
  ACTIVE
  DEPRECATED
}

enum PaymentMethod {
  ACH
  WIRE
  STRIPE_CONNECT       // V1 default — already wired via #54
}

enum PricingModel {
  FIXED
  QUOTE_BASED
  VOLUME_TIERED
}

enum InvoiceCycle {
  PER_ORDER
  WEEKLY
  MONTHLY
}

// Admin-managed library of contract versions. Partners reference, never edit.
// V1 seed: one row, 'STANDARD_V1.0'.
// V1.5+: additional rows can be created for per-partner side agreements;
//        admin sets PartnerCommercialTerms.contractOverrideId to point at them.
model ContractTerms {
  id                    String          @id @default(cuid())
  version               String          @unique                          // 'STANDARD_V1.0', 'ACME_CUSTOM_V1' (V1.5+)
  name                  String
  description           String
  status                ContractStatus
  failureResponsibility Json                                              // matrix per docs/PARTNER_ONBOARDING.md §2.5
  paymentTerms          Json                                              // standard payment timing + supported methods
  pricingModelOptions   PricingModel[]                                    // which models partners under this contract can offer
  invoiceCycleOptions   InvoiceCycle[]
  disputePolicy         Json
  effectiveFrom         DateTime
  effectiveTo           DateTime?
  pdfFileId             String?                                           // R2 reference to human-signable PDF
  createdAt             DateTime        @default(now())
  partnersReferencing   PartnerCommercialTerms[] @relation("StandardContract")
  partnersOverriding    PartnerCommercialTerms[] @relation("OverrideContract")
}

model PartnerCommercialTerms {
  id                     String         @id @default(cuid())
  partnerId              String         @unique
  contractTermsId        String                                            // FK — defaults to current STANDARD_V1.0 ACTIVE row
  // V1.5+ extensibility hook (nullable; never set in V1 — every partner uses standard contract)
  contractOverrideId     String?
  paymentMethod          PaymentMethod  @default(STRIPE_CONNECT)
  payoutTimingDays       Int            @default(7)
  pricingModel           PricingModel   @default(FIXED)
  invoiceCycle           InvoiceCycle   @default(PER_ORDER)
  signedAt               DateTime
  signedById             String                                            // User who clicked "I accept the contract"
  stripeConnectAccountId String?                                           // mirrors User.stripeAccountId for partner-level scoping
  updatedAt              DateTime       @updatedAt
  partner                Partner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  contractTerms          ContractTerms  @relation("StandardContract", fields: [contractTermsId], references: [id])
  contractOverride       ContractTerms? @relation("OverrideContract", fields: [contractOverrideId], references: [id])
}

// -----------------------------------------------------------------------------
// LAYER 5 — System Integration (V1 = dashboard-only baseline for everyone)
// -----------------------------------------------------------------------------

enum InventorySyncMode {
  NONE              // V1 default — no automatic inventory sync
  MANUAL            // V1.5+ — partner enters inventory adjustments by hand
  CSV_BATCH         // V1.5+ — periodic CSV import/export
  WEBHOOK           // V2 — push notifications to partner endpoint
  API               // V2 — full programmatic sync
}

model PartnerIntegrationCapability {
  id                   String            @id @default(cuid())
  partnerId            String            @unique
  hasDashboardOnly     Boolean           @default(true)                   // everyone has this in V1
  canUseCSVImport      Boolean           @default(false)                  // V1.5+ feature flag
  canUseCSVExport      Boolean           @default(false)
  hasWebhookEndpoint   Boolean           @default(false)                  // V2+ feature flag
  webhookUrl           String?
  webhookSigningSecret String?                                            // rotated by admin
  hasAPIIntegration    Boolean           @default(false)                  // V2+ feature flag
  apiKeyId             String?                                            // future FK to APIKey rotation system (V2)
  inventorySyncMode    InventorySyncMode @default(NONE)
  updatedAt            DateTime          @updatedAt
  partner              Partner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// OnboardingProgress — per-layer completion tracking for the wizard at
// /partner/onboarding. Distinct from the legacy Partner.onboardingProgress
// Json field (Phase A) which is preserved for back-compat.
// -----------------------------------------------------------------------------

enum LayerStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED                  // partner has submitted; awaiting admin review
  APPROVED                   // admin approved this layer
  CHANGES_REQUESTED          // admin requested changes via changeRequests Json
}

model PartnerOnboardingProgress {
  id                    String      @id @default(cuid())
  partnerId             String      @unique
  layer1Identity        LayerStatus @default(NOT_STARTED)
  layer2Capability      LayerStatus @default(NOT_STARTED)
  layer3Standards       LayerStatus @default(NOT_STARTED)
  layer4Commercial      LayerStatus @default(NOT_STARTED)
  layer5Integration     LayerStatus @default(NOT_STARTED)
  // Structured admin feedback per layer — array of { category, description, createdAt, resolvedAt? }
  // Partner sees these as a checklist on /partner/my-application with deep-links to fix.
  layer1ChangeRequests  Json?
  layer2ChangeRequests  Json?
  layer3ChangeRequests  Json?
  layer4ChangeRequests  Json?
  layer5ChangeRequests  Json?
  lastActivityAt        DateTime?
  partner               Partner     @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

// =============================================================================
// CREATOR ONBOARDING + BRAND ASSETS — V1
// Specs: docs/CREATOR_ONBOARDING.md + docs/DESIGN_STUDIO_REBUILD.md §4
// =============================================================================
//
// Creator onboarding = 5-step guided stepper. Brand Assets = simple 3-section
// page (Logos / Colors / Fonts) that feeds the Fabric.js Design Studio canvas.
//
// V1 has ONE curated library that survives: TypographyFont (~24 Google Fonts
// rows). Creators pick 1-3 of these per brand. BrandStylePreset / ColorPalette
// / TypographyPair were dropped 2026-05-26 as scope creep (web design-system
// concepts that don't apply to packaging design). PhotographyStyle and
// IllustrationStyle enums also dropped.

enum FontSource {
  GOOGLE_FONTS      // V1 default — all curated fonts come from Google Fonts
  ADOBE             // V1.1+
  PRIVATE_LICENSED  // V1.5+ — partner uploads with license attestation
}

enum BrandLibraryStatus {
  DRAFT
  ACTIVE
  DEPRECATED
}

enum OnboardingStepStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED            // distinguishes deliberate skip from "not yet started"
}

// -----------------------------------------------------------------------------
// CURATED LIBRARIES — admin-managed, referenced by Brand
// -----------------------------------------------------------------------------

// BrandStylePreset / ColorPalette / TypographyPair models were dropped 2026-05-26
// per docs/DESIGN_STUDIO_REBUILD.md §4 — they were web design-system concepts
// (style presets, 11-role color tokens, typographic pair lockups) that do not
// apply to packaging-design where the canvas tools choose per-element sizing
// and the creator picks individual swatches + fonts directly.
//
// TypographyFont is the ONLY brand library model that survives — creators pick
// 1-3 fonts from this catalog and they're stored as Brand.brandFontIds[].

// Individual font rows (Google Fonts at V1 launch). Creators pick 1-3 of these
// per brand; references stored as Brand.brandFontIds[].
model TypographyFont {
  id                  String     @id @default(cuid())
  family              String                                // 'Inter', 'Playfair Display'
  weight              String                                // 'Regular', 'Bold', 'Black'
  style               String                                // 'Normal', 'Italic'
  source              FontSource @default(GOOGLE_FONTS)
  webfontUrl          String?                               // for browser rendering
  printFileAssetId    String?                               // OTF/TTF asset for label PDF rendering (R2)
  unicodeRanges       String[]                              // subset support (latin, latin-ext, ...)
  licenseTerms        String                                // brief license summary for creator
  status              BrandLibraryStatus
  createdAt           DateTime   @default(now())
  @@unique([family, weight, style])
}

// -----------------------------------------------------------------------------
// CreatorOnboardingProgress — 5-step stepper tracking (per Brand)
// Distinct from PartnerOnboardingProgress (different ceremony, different shape).
// -----------------------------------------------------------------------------

model CreatorOnboardingProgress {
  id                       String                @id @default(cuid())
  brandId                  String                @unique
  step1TellUsAboutYou      OnboardingStepStatus  @default(NOT_STARTED)  // markets + region + brand name
  step2PaymentSetup        OnboardingStepStatus  @default(NOT_STARTED)  // Stripe Checkout for funding production orders
  step3ConnectChannel      OnboardingStepStatus  @default(NOT_STARTED)  // Shopify/WC/BigC/Amazon/Direct (optional)
  step4BrandIdentity       OnboardingStepStatus  @default(NOT_STARTED)  // Brand Quickstart (logo, palette, typography, voice tags, tagline)
  step5FirstProduct        OnboardingStepStatus  @default(NOT_STARTED)  // marketplace browse + pick first product
  lastActivityAt           DateTime?
  brand                    Brand                 @relation(fields: [brandId], references: [id], onDelete: Cascade)
}

// =============================================================================
// MANUFACTURER PRODUCT BUILDER — Packaging + Certificates + Notes + FlavorPresets
// Spec: docs/MANUFACTURER_PRODUCT_BUILDER.md
// =============================================================================
//
// V1 schema additions covering:
//   §5  FlavorPreset (overlay on base recipe — one product, many curated flavor variations)
//   §6  Two-tier Packaging (admin canonical PackagingType + partner-owned PackagingSystem
//       with admin override layer; PackagingSurface with die-line files per surface)
//   §7  Certificate library (admin CertificateType catalog + partner
//       PartnerCertificateInstance with private PDFs + ProductCertificate link
//       with per-size scope via appliesToPackagingSystemIds[])
//   §8  ProductReviewItem (structured admin feedback checklist)
//   §8a ProductNote (per-product partner ↔ admin thread)
//   §15 ProductTemplatePackaging (the per-size bridge with pricing tiers, MOQ,
//       lead time, surface-die-line overrides)

enum PackagingTopology {
  SINGLE_CONTAINER       // one jar / bottle / pouch / can / box
  MULTI_CONTAINER_BOX    // outer carton holding N inner containers (variety pack, sampler)
  STICK_PACK             // single-serve sticks (powder, supplement)
  SACHET                 // single-serve flexible sachets
  CASE                   // shipper/case (24-pack, etc.) — wholesale unit
  CAPSULE_JAR            // bottle of capsules/tablets (supplement form factor)
  POUCH_STAND_UP         // stand-up pouch with resealable zipper
  POUCH_FLAT             // flat sealed pouch
  TUBE                   // squeeze tube (sauces, gels)
  OTHER                  // catch-all (V1.5+ admin can add canonical types via PackagingType)
}

enum FlavorMode {
  SINGLE                 // one flavor per packaging unit (1 jar = 1 flavor)
  MULTI                  // multiple flavors per packaging unit (variety pack)
}

enum FlavorPolicy {
  CREATOR_PICK           // creator selects flavor(s) per unit
  PARTNER_FIXED          // partner has fixed assortment; creator can't customize
}

enum PackagingStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum PackagingTypeStatus {
  ACTIVE
  DEPRECATED
}

enum CertificateTypeStatus {
  ACTIVE
  DEPRECATED
}

enum PartnerCertInstanceStatus {
  PENDING_REVIEW
  VERIFIED
  EXPIRED                // auto-transitioned when expiresAt passes
  REJECTED
}

enum NoteAuthor {
  PARTNER
  ADMIN
}

enum FlavorPresetStatus {
  ACTIVE
  DRAFT
  RETIRED
}

// -----------------------------------------------------------------------------
// PACKAGING — two-tier admin canonical + partner-owned with override layer
// -----------------------------------------------------------------------------

// Admin-curated canonical packaging taxonomy. Starts EMPTY at V1 launch and grows
// as admin clusters partner-contributed PackagingSystems via the promotion
// queue (task #135).
model PackagingType {
  id                String              @id @default(cuid())
  slug              String              @unique             // 'hdpe-jar-16oz-wide-mouth'
  displayName       String                                   // canonical name shown publicly
  imageFileId       String?                                  // admin-curated reference photo (Asset/PartnerFile soft FK)
  defaultTopology   PackagingTopology
  defaultDimensions Json?                                    // { lengthMm, widthMm, heightMm }
  defaultSurfaces   Json?                                    // [{ name, defaultBleedMm }]
  status            PackagingTypeStatus @default(ACTIVE)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  systems           PackagingSystem[]
}

// Partner-owned packaging system — links optionally to a canonical PackagingType.
// Display-name + image resolution priority:
//   1. overrideDisplayName / overrideImageFileId  (admin override)
//   2. linked PackagingType.displayName / imageFileId
//   3. partnerName / partnerImageFileId  (fallback)
model PackagingSystem {
  id                    String           @id @default(cuid())
  partnerId             String
  packagingTypeId       String?                              // optional FK to canonical type
  // Partner-supplied (fallback when no type link and no admin override):
  partnerName           String
  partnerImageFileId    String?                              // soft FK to Asset/PartnerFile
  // Admin override layer (wins over partner if set):
  overrideDisplayName   String?
  overrideImageFileId   String?
  // Physical implementation:
  topology              PackagingTopology
  unitCount             Int              @default(1)
  flavorMode            FlavorMode       @default(SINGLE)
  flavorPolicy          FlavorPolicy     @default(CREATOR_PICK)
  moq                   Int
  dimensions            Json?                                // { lengthMm, widthMm, heightMm }
  maxWeightG            Int?
  status                PackagingStatus  @default(DRAFT)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  // Relations
  partner               Partner          @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  packagingType         PackagingType?   @relation(fields: [packagingTypeId], references: [id])
  surfaces              PackagingSurface[]
  templates             ProductTemplatePackaging[]
  @@index([partnerId, status])
  @@index([packagingTypeId])
}

// Per-surface die-line + print spec on a PackagingSystem.
// E.g., a 16oz jar has surfaces { Front, Back, Lid } — each its own die-line file.
model PackagingSurface {
  id                  String           @id @default(cuid())
  packagingSystemId   String
  name                String                                 // 'Front', 'Lid', 'Inner Tray'
  dieLineFileId       String?                                // soft FK to PartnerFile (R2)
  printableAreaSqIn   Float?
  bleedMm             Float            @default(3)
  // Print spec (from FOD admin delta §1.1; V1 schema, V1.1 visual zone editor)
  printDpi            Int?
  colorMode           String?                                // 'CMYK', 'RGB', 'BW'
  mandatoryZones      Json?                                  // [{ type, x, y, w, h, required }] — V1.1 zone editor
  registrationMarks   Json?
  packagingSystem     PackagingSystem  @relation(fields: [packagingSystemId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// CERTIFICATES — admin canonical types + partner instances + product links
// -----------------------------------------------------------------------------

// Admin-curated catalog of recognised certifications (NSF, USDA Organic, etc.).
// Each entry has a branded badge thumbnail for public display + verification notes.
// V1 seed: 12 starter types per spec §7.2.
model CertificateType {
  id                  String                       @id @default(cuid())
  name                String
  slug                String                       @unique
  thumbnailFileId     String?                                            // admin-uploaded badge, ~256x256
  description         String                                              // shown on hover/tooltip publicly
  verificationNotes   String?                                             // what admin looks for when verifying partner uploads
  status              CertificateTypeStatus        @default(ACTIVE)
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  partnerInstances    PartnerCertificateInstance[]
}

// Partner's actual certification — they upload the PDF (private to admin),
// admin verifies in queue (task #129). Status auto-flips to EXPIRED on expiry.
// Only ACTIVE/VERIFIED instances appear in the product builder's certificate picker.
model PartnerCertificateInstance {
  id                  String                       @id @default(cuid())
  partnerId           String
  certificateTypeId   String
  pdfFileId           String                                              // PartnerFile, private — never exposed publicly
  certificateNumber   String?
  issuingBody         String?
  issueDate           DateTime?
  expiryDate          DateTime
  status              PartnerCertInstanceStatus    @default(PENDING_REVIEW)
  reviewedById        String?                                             // admin User
  reviewedAt          DateTime?
  rejectionReason     String?
  notes               String?                                             // optional partner-supplied notes for admin
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  partner             Partner                      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  certificateType     CertificateType              @relation(fields: [certificateTypeId], references: [id])
  productAssignments  ProductCertificate[]
  @@index([partnerId, status])
  @@index([expiryDate])
}

// Per-product certificate selections. Per-size scope: NULL appliesToPackagingSystemIds
// means cert applies to ALL of the product's PackagingSystems. Array form scopes
// to specific sizes (e.g., NSF only certified for the 16oz SKU).
model ProductCertificate {
  productTemplateId            String
  instanceId                   String
  appliesToPackagingSystemIds  String[]                                   // NULL/empty = all sizes
  productTemplate              ProductTemplate            @relation(fields: [productTemplateId], references: [id], onDelete: Cascade)
  instance                     PartnerCertificateInstance @relation(fields: [instanceId], references: [id])
  @@id([productTemplateId, instanceId])
}

// -----------------------------------------------------------------------------
// PRODUCT REVIEW + NOTES — admin feedback + per-product partner ↔ admin thread
// -----------------------------------------------------------------------------

// Structured admin feedback items (NOT free-text comments — those are ProductNote).
// Each item is a checklist entry the partner must resolve before resubmit.
model ProductReviewItem {
  id                  String           @id @default(cuid())
  productTemplateId   String
  category            String                                              // 'ingredients' | 'packaging' | 'media' | 'compliance' | 'other'
  description         String
  resolved            Boolean          @default(false)
  resolvedAt          DateTime?
  createdById         String                                              // admin User
  productTemplate     ProductTemplate  @relation(fields: [productTemplateId], references: [id], onDelete: Cascade)
  createdAt           DateTime         @default(now())
  @@index([productTemplateId, resolved])
}

// Per-product comment thread between partner and admin. Use for messy human
// stuff (clarifications, photo requests, supplier-change heads-ups). Separate
// from ProductReviewItem (which is structured blocking checklist).
model ProductNote {
  id                  String           @id @default(cuid())
  productTemplateId   String
  authorId            String                                              // User who wrote it
  authorType          NoteAuthor
  body                String
  attachmentFileId    String?                                             // soft FK to PartnerFile
  editedAt            DateTime?
  productTemplate     ProductTemplate  @relation(fields: [productTemplateId], references: [id], onDelete: Cascade)
  createdAt           DateTime         @default(now())
  @@index([productTemplateId, createdAt])
}

// -----------------------------------------------------------------------------
// PRODUCT TEMPLATE ↔ PACKAGING (per-size bridge with pricing + per-product overrides)
// -----------------------------------------------------------------------------

model ProductTemplatePackaging {
  // Bridge between a product template and one of its size/packaging configurations.
  // Per-size pricing, MOQ, lead time, and surface-die-line overrides live here
  // (NOT on ProductTemplate itself — different sizes have different prices).
  productTemplateId String
  packagingSystemId String
  basePriceCents    Int                                                   // per unit at base MOQ
  moqOverride       Int?                                                  // overrides PackagingSystem.moq if set
  leadTimeDays      Int                                                   // absolute, not delta from system default
  pricingTiers      Json                                                  // [{ minQuantity, unitPriceCents }]
  surfaceOverrides  Json?                                                 // [{ surfaceId, overrideFileId }] per-product die-line overrides
  productTemplate   ProductTemplate  @relation(fields: [productTemplateId], references: [id], onDelete: Cascade)
  packagingSystem   PackagingSystem  @relation(fields: [packagingSystemId], references: [id])
  @@id([productTemplateId, packagingSystemId])
}

// -----------------------------------------------------------------------------
// FLAVOR PRESETS — one product, many curated flavor variations (NOT separate recipes)
// Per docs/MANUFACTURER_PRODUCT_BUILDER.md §5
// -----------------------------------------------------------------------------

model FlavorPreset {
  id                   String              @id @default(cuid())
  productTemplateId    String
  name                 String                                             // 'Chocolate', 'Vanilla', 'Strawberry'
  swatchHex            String?                                            // '#5C3317' for picker
  swatchImageFileId    String?                                            // small jar/scoop photo for picker
  // The overlay — defines which slot picks apply for this flavor + flavor-only extras
  slotResolution       Json                                               // [{ slotId, optionId | { customIngredientId, qty, unit } }]
  extras               Json?                                              // [{ name, ingredientId, qty, unit }] flavor-only ingredients
  priceDeltaCents      Int                 @default(0)                    // additive to per-size base price
  status               FlavorPresetStatus  @default(ACTIVE)
  sortOrder            Int                 @default(0)
  // V1 — per-flavor nutrient overrides (e.g., strawberry adds water content; shifts moisture)
  nutrientOverrides    Json?                                              // [{ nutrient, value, reason }] — preset overrides win on conflict with ProductTemplate.nutrientOverrides
  productTemplate      ProductTemplate     @relation(fields: [productTemplateId], references: [id], onDelete: Cascade)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  @@index([productTemplateId, status, sortOrder])
}

// =============================================================================
// INGREDIENT SOURCING (#136) + USAGE TRACKING + DICTIONARIES (#143)
// Spec: docs/MANUFACTURER_PRODUCT_BUILDER.md §4a
// =============================================================================
//
// Three-tier sourcing model: USDA FDC (~10k high-quality Foundation/SR Legacy
// + ~30-50k filtered Branded Foods) + iLaunchify Curated Library (~1,000-1,200
// supplement-specific items, admin-curated) + Partner-Private (each partner's
// supplier SKUs with COA-derived nutrient panels).
//
// Sliding verification governance — SELF_ATTESTED partner-private ingredients
// are usable in published products immediately. Admin scales control via:
//   - Hard blocks (banned dictionary)
//   - Soft warns (controversial dictionary)
//   - Red flags in product approval queue when >5% of recipe weight
//   - Library promotion queue that absorbs cross-partner repeats over time

enum IngredientSource {
  USDA                  // imported from USDA FoodData Central
  LIBRARY               // iLaunchify-curated supplement-specific item
  PARTNER_PRIVATE       // partner-uploaded with COA, scoped to one partner via ownerPartnerId
}

enum VerificationStatus {
  SELF_ATTESTED         // default for new PARTNER_PRIVATE; usable in published products
  ADMIN_VERIFIED        // admin reviewed COA/nutrient values
  LIBRARY_PROMOTED      // promoted from PARTNER_PRIVATE to public LIBRARY (default for USDA + LIBRARY rows)
}

enum BioengineeredStatus {
  NONE                  // confirmed not bioengineered
  BIOENGINEERED         // is a BE food per USDA BE Standard 2022
  DERIVED_FROM_BIOENGINEERED  // ingredient derived from BE source
  NOT_APPLICABLE        // not in scope (e.g., minerals, vitamins, salt)
}

// -----------------------------------------------------------------------------
// IngredientUsage — drives personalized search ranking in IngredientPicker
// per docs/MANUFACTURER_PRODUCT_BUILDER.md §4a.5a (Recipal-parity trick).
// Updated on every "save slot" / "save preset" action.
// -----------------------------------------------------------------------------

model IngredientUsage {
  id           String     @id @default(cuid())
  partnerId    String                                          // who used this ingredient
  ingredientId String
  useCount     Int        @default(1)
  lastUsedAt   DateTime   @default(now())
  // Relations
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  @@unique([partnerId, ingredientId])
  @@index([partnerId, lastUsedAt(sort: Desc)])                  // primary sort key for personalized ranking
}

// -----------------------------------------------------------------------------
// BannedIngredient — hard-block dictionary
// Partner literally cannot save an ingredient whose name matches an active row.
// Seeded with ~30 entries: ephedra, sibutramine, undeclared stimulants,
// certain SARMs precursors, undeclared steroids, etc.
// Admin manages via /admin/library/banned-ingredients (V1.5+ UI; V1 = seed only).
// -----------------------------------------------------------------------------

model BannedIngredient {
  id              String   @id @default(cuid())
  // Matchers — at least one must be populated
  matchName       String?                                       // case-insensitive exact match on Ingredient.name or internalName
  matchPattern    String?                                       // optional regex (advanced)
  casNumber       String?                                       // Chemical Abstracts Service number when known
  // Context
  reason          String                                        // why this is banned (FDA action, safety concern, regulatory)
  reference       String?                                       // URL to FDA notice / journal article / regulation
  isActive        Boolean  @default(true)
  effectiveFrom   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([isActive, matchName])
  @@index([casNumber])
}

// -----------------------------------------------------------------------------
// ControversialIngredient — soft-warn dictionary
// Partner can save the ingredient but sees a warning at creation time AND
// admin gets a high-priority notification on use in any product.
// Seeded with ~40 entries: high-dose caffeine combinations, kratom, certain
// herbal extracts with uncertain safety profile, etc.
// -----------------------------------------------------------------------------

model ControversialIngredient {
  id              String   @id @default(cuid())
  matchName       String?
  matchPattern    String?
  casNumber       String?
  // Context
  concern         String                                        // what the concern is (interaction, dosing, regulatory ambiguity)
  recommendation  String?                                       // suggested action (lower dose, alternative, COA required)
  reference       String?
  isActive        Boolean  @default(true)
  effectiveFrom   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([isActive, matchName])
}

// =============================================================================
// LABEL DESIGN TEMPLATE — compatibility + tier + provenance enums (#147)
// Spec: docs/DESIGN_STUDIO.md §3
// Schema applies to DesignLibraryItem (which is the "LabelDesignTemplate" the
// spec refers to).
// =============================================================================

enum LabelTemplateSurface {
  FRONT
  BACK
  LID
  FULL_WRAP
  SLEEVE
  NECK
}

enum LabelTemplateTier {
  REGULAR             // free with any partner plan
  PREMIUM             // paid (one-time per use or via plan tier) — billing flow lands V1.5
  EXCLUSIVE           // limited-license; max exclusiveSeats partners can claim
}

enum LabelTemplateCreator {
  ADMIN               // hand-curated by iLaunchify ops
  DESIGNER            // contractor-produced (the ~20 hand-curated V1 launch seed will be this)
  AI_AGENT            // V2+ Trend Researcher + Template Generator pipeline
  PARTNER             // V2+ partners contributing templates
}

enum LabelTemplateStatus {
  DRAFT
  PENDING_REVIEW      // submitted (AI-generated or partner-submitted) awaiting human curator approval
  ACTIVE              // available in Design Studio gallery
  DEPRECATED          // hidden from gallery; existing creator Designs still valid
}
