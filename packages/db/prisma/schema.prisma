enum ProductCategory {
  FOOD
  BEVERAGE_FUNCTIONAL
  SUPPLEMENT
  // V1.5+: BEAUTY, PET_FOOD, BABY_FOOD
}

enum ProductStatus {
  DRAFT
  IN_REVIEW
  COMPLIANT
  PUBLISHED
  PAUSED
  ARCHIVED
}

// How a creator's UPC/EAN got onto the product. V1 only writes USER_PROVIDED;
// PLATFORM_ASSIGNED reserves space for a future managed-UPC service, and
// GS1_VALIDATED reserves space for an integration against GS1's GEPIR lookup.
enum GtinSource {
  USER_PROVIDED       // creator pasted their own (default)
  GS1_VALIDATED       // future: confirmed against gs1.org via API
  PLATFORM_ASSIGNED   // future: iLaunchify-managed UPC service (V2+)
}

// How the product's packaging displays a barcode. V1 ships NONE / RETAIL_UPC /
// INTERNAL_SKU; INTERNAL_SKU prints a Code 128 of the SKU for warehouse
// routing without claiming to be a real UPC (per Pavel's pre-launch case).
enum BarcodeMode {
  NONE                // no barcode rendered
  RETAIL_UPC          // render gtin as the chosen format on packaging
  INTERNAL_SKU        // render internalSku as Code 128 with "INTERNAL" caption
}

enum RecipeStatus {
  DRAFT
  CALCULATED
  COMPLIANCE_CHECKED
  APPROVED
}

