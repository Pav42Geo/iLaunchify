// =============================================================================
// ENUMS — ORDER
// =============================================================================

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  ROUTING
  IN_FULFILLMENT
  READY_TO_SHIP
  SHIPPED
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
  ON_HOLD
  DISPUTED
}

enum DispatchType {
  PRODUCT
  LABEL
}

enum DispatchStatus {
  PENDING_ACCEPT
  ACCEPTED
  // Phase H — partner needs the creator to adjust the manifest before
  // accepting. Sits here until the creator submits an adjustment.
  CHANGES_REQUESTED
  PRODUCING
  QUALITY_CHECK    // partner is QC'ing the batch before flipping to READY
  FAILED_QC        // QC failed; needs admin attention (manual reroute or remake)
  READY
  SHIPPED
  IN_TRANSIT
  DELIVERED
  DECLINED
  TIMED_OUT
  // Phase H — partner accepted but later can't deliver (capacity
  // surprise, machine breakdown). Triggers auto-reroute for fungible
  // service types.
  WITHDRAWN
  CANCELLED
}

enum DispatchDeclineReason {
  AT_CAPACITY
  CANNOT_FULFILL_SPEC
  PRICING_DISPUTE
  OTHER
}

// Phase H — derived from per-dispatch acceptance state. Drives the
// creator's order detail banner + holds Order.status at ROUTING until
// FULLY_ACCEPTED (at which point Order flips to IN_FULFILLMENT and
// Stripe transfers fire).
enum AggregateApprovalStatus {
  AWAITING_PARTNERS         // ≥1 dispatch still PENDING_ACCEPT, none ACCEPTED
  PARTIALLY_ACCEPTED        // some ACCEPTED, some still PENDING_ACCEPT
  CHANGES_REQUESTED         // ≥1 dispatch CHANGES_REQUESTED — creator must adjust
  FULLY_ACCEPTED            // every dispatch ACCEPTED → Order ready for fulfillment
  CANCELLED                 // order killed (manufacturer reject or admin cancel)
}

// Phase G8 — production bundle generation status. Manifest is built at
// order placement (synchronous); print-ready PDF + die-line SVG render
// is V1.5 worker territory.
enum BundleStatus {
  PENDING_GENERATION    // manifest done, files not yet rendered
  READY                 // bundleAssetId populated, ready for the partner
  FAILED                // generator hit an error — admin alert
}

