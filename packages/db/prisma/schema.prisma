// =============================================================================
// iLaunchify v2 Prisma Schema — V1 Initial Release
// =============================================================================
//
// Ported and reorganized from FOD-reference/prisma/schema.prisma, with V1
// additions per the architecture decision docs in docs/.
//
// Reading order: enums → identity → marketplace identity → brand & products →
// ingredients & recipes → compliance → templates & design → assets → orders →
// payments → carts → consumers → market & rule packs.
//
// V1 STATUS: this is the initial schema. It compiles cleanly and supports
// every feature in the 12-week roadmap. Models marked "(V1.5+)" are
// declared so foreign keys exist but their UIs are not built in V1.
//
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS — IDENTITY & ROLES
// =============================================================================

enum UserRole {
  ADMIN
  CREATOR
  PARTNER
}

enum StripeAccountStatus {
  NONE
  PENDING
  RESTRICTED
  ACTIVE
  REJECTED
  DEAUTHORIZED
}

// =============================================================================
// ENUMS — PARTNER & SERVICE
// =============================================================================

// Partner lifecycle FSM. The original 6 values are Phase-A legacy and remain
// supported for existing rows; new code uses the 8 V1 values added per
// docs/PARTNER_ONBOARDING.md §3 activation FSM:
//
//   LEAD → IDENTITY_PENDING_REVIEW → IDENTITY_VERIFIED → OPS_PENDING_REVIEW
//        → OPERATIONALLY_CONFIGURED → ACTIVE → (INTEGRATION_ENHANCED)
//        + side states PAUSED / SUSPENDED / TERMINATED
//
// Legacy mapping (for back-compat when reading Phase-A rows):
//   DRAFT       → LEAD
//   INVITED     → LEAD
//   IN_PROGRESS → LEAD
//   UNDER_REVIEW → IDENTITY_PENDING_REVIEW
//   ACTIVE      → ACTIVE (same)
//   SUSPENDED   → SUSPENDED (same)
enum PartnerStatus {
  // V1 (canonical from 2026-05-24 forward)
  LEAD
  IDENTITY_PENDING_REVIEW
  IDENTITY_VERIFIED
  OPS_PENDING_REVIEW
  OPERATIONALLY_CONFIGURED
  ACTIVE
  INTEGRATION_ENHANCED
  PAUSED
  SUSPENDED
  TERMINATED
  // Phase-A legacy values (deprecated; preserved for back-compat with existing rows)
  DRAFT
  INVITED
  IN_PROGRESS
  UNDER_REVIEW
}

enum ServiceType {
  MANUFACTURING
  COPACKING
  LABEL_PRINTING
  WAREHOUSE          // 3PL / fulfillment partner — holds creator inventory after production delivery
}

enum ServiceStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum DisclosureLevel {
  FULL          // "Manufactured by Acme Foods, San Jose, CA"
  CITY_STATE    // "Manufactured for [Creator] in San Jose, CA"
  ANONYMOUS     // "Manufactured for [Creator] in the USA"
}

